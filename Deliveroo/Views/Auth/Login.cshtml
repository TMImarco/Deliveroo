@model Deliveroo.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<h1>@ViewData["Title"]</h1>

<div class="text-center">

    <a class="nav-arrow back-btn"
       asp-action="Index"
       asp-controller="Home">
        ↵
    </a>

    <form method="post"
          asp-controller="Auth"
          asp-action="Login">

        <p class="testo-rosso">@ViewData["errore"]</p>

        <div class="mt-2">
            <label asp-for="Username"></label>
            <input asp-for="Username" class="form-control" />
        </div>

        <div class="mt-2" style="margin-bottom: 10px;">
            <label asp-for="Password"></label>
            <input type="password"
                   asp-for="Password"
                   class="form-control" />
        </div>

        <p>
            <button type="submit"
                    class="btn btn-primary">
                Entra
            </button>
        </p>

    </form>
</div>

@section Styles
{
    <link rel="stylesheet" href="/cssAdmin/Login.css" />
}