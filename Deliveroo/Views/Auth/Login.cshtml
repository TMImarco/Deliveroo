@model Deliveroo.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
    ViewData["HideSearch"] = true;
}

@section NavbarLinks { }

<div class="auth-wrapper">
    <div class="auth-card">

        <div class="auth-header">
            <span class="auth-eyebrow">Bentornato</span>
            <h1 class="auth-title">Accedi</h1>
            <p class="auth-sub">Inserisci le tue credenziali per continuare</p>
        </div>

        @if (ViewData["errore"] != null)
        {
            <div class="auth-error">@ViewData["errore"]</div>
        }

        <form method="post"
              asp-controller="Auth"
              asp-action="Login">

            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <div class="auth-field">
                <label asp-for="Username">Username</label>
                <input asp-for="Username" autocomplete="username" />
                <span asp-validation-for="Username" class="auth-validation"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Password">Password</label>
                <input type="password" asp-for="Password" autocomplete="current-password" />
                <span asp-validation-for="Password" class="auth-validation"></span>
            </div>

            <hr class="auth-divider" />

            <button type="submit" class="auth-btn">Entra</button>

        </form>

        <p class="auth-switch">
            Non hai un account?
            <a asp-controller="Auth" asp-action="Registrazione"
               asp-route-returnUrl="@ViewBag.ReturnUrl">Registrati</a>
        </p>

    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="/cssAdmin/Login.css" />
}