@{
    ViewData["Title"] = "Admin - Aggiungi Articolo";
    Layout = "_LayoutAdmin"; //il layout è quello dell'utente (va bene)
}

<div class="macro-section">
    <div class="container">
        <div class="page-split">

            <!-- SINISTRA (da togliere e centrare)-->
            <div class="left-col">

                <!-- BOTTONE BACK (fare un pulsante per annulare l'operazione-->
                <div></div>

                <div class="article-split">
                    <div class="article-left">
                        <!-- foto articolo -->
                    </div>

                    <!--da sostiuire con bottoni per aggiungere tutti gli elementi + aggiungere categoria-->
                    <div class="article-right">
                        <div class="article-right-content">
                            <!-- nome articolo (h1) -->
                            <!-- desccrizione articolo (<p class="descrizione">) -->
                            <div class="article-divider"></div>
                            <!-- prezzo articolo (<p class="prezzo">) -->
                            <div class="article-divider"></div>
                        </div>

                        <!--bottone per completamento operazione-->
                        <button class="add-btn">Fine</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!--da modificare-->
@section Styles {
    <link rel="stylesheet" href="/css/InserimentoArticolo.css"/>
}