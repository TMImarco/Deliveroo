@{
    ViewData["Title"] = "Admin - Aggiungi Articolo";
    Layout = "_LayoutAdmin"; //il layout è quello dell'utente (va bene)

    List<Categoria> categorie = Model;
}

<div class="macro-section">
    <div class="container">
        <div class="page-split">

            <!-- SINISTRA (da togliere e centrare)-->
            <div class="left-col">

                <!-- BOTTONE BACK (fare un pulsante per annullare l'operazione-->
                <button class="btn btn-primary">
                    ANNULLA
                </button>

                <form method="post"
                      asp-action="AggiungiNuovoArticolo"
                      enctype="multipart/form-data">
                    <div class="article-split">
                        <div class="article-left">
                            <!-- INPUT FILE per FOTO ? -->
                            <input type="file" id="foto" name="foto">
                        </div>

                        <!--da sostituire con bottoni per aggiungere tutti gli elementi + aggiungere categoria-->
                        <div class="article-right">
                            <div class="article-right-content">
                                <!-- nome articolo (h1) -->
                                <!--INPUT NOME-->
                                <input type="text" id="nome" name="nome">

                                <!-- descrizione articolo (<p class="descrizione">) -->
                                <!--INPUT DESCRIZIONE-->
                                <input type="text" id="descrizione" name="descrizione">

                                <div class="article-divider"></div>

                                <!-- prezzo articolo (<p class="prezzo">) -->
                                <!--INPUT PREZZO-->
                                <input type="number" id="prezzo" name="prezzo">

                                <div class="article-divider"></div>

                                <!--INPUT CATEGORIA-->
                                <select name="categorie" id="categorie">
                                    @foreach (var c in categorie)
                                    {
                                        <option value="@c.IdCategoria">@c.Nome</option>
                                    }
                                </select>
                            </div>

                            <!--bottone per completamento operazione (per ora non funzionante per evitare casini
                            finche' non viene sistemato il caricamento della foto e la variabile del prezzo nel HomeController
                            <input type="submit" value="FINE" class="add-btn"/>
                            -->
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!--da modificare-->

@section Styles {
    <link rel="stylesheet" href="/cssAdmin/ModificaArticolo.css"/>
}