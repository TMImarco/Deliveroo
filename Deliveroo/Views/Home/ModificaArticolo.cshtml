@using Deliveroo.Tabelle
@{
    ViewData["Title"] = "Admin - Modifica Articoli";
    Layout = "_LayoutAdmin";
    Articolo art = Model.Item1; //item 1 della tupla
    List<Categoria> categorie = Model.Item2; //item 2 della tupla
}

<h1>MODIFICA L'ARTICOLO</h1>

<div class="macro-section">
    <div class="container">
        <div class="page-split">

            <!-- SINISTRA -->
            <div class="left-col">

                <!-- NAVIGAZIONE PREV / NEXT 
                Piuttosto di ritornare sempre alla pagina di tutti gli articoli, ci sono i bottoni avanti e indietro per navigare facilmente -->
                <div class="article-nav">
                    @if (ViewBag.IdPrev != null)
                    {
                        <a class="nav-arrow prev" asp-action="ModificaArticolo"
                           asp-route-id="@ViewBag.IdPrev">&#8592;</a>
                    }
                    else
                    {
                        <span class="nav-arrow prev disabled">&#8592;</span>
                    }

                    @if (ViewBag.IdNext != null)
                    {
                        <a class="nav-arrow next" asp-action="ModificaArticolo"
                           asp-route-id="@ViewBag.IdNext">&#8594;</a>
                    }
                    else
                    {
                        <span class="nav-arrow next disabled">&#8594;</span>
                    }
                </div>

                <!-- BOTTONE BACK -->
                <a class="nav-arrow back-btn"
                   asp-action="ArticoliAdmin"
                   asp-route-idCategoria="@ViewBag.IdCategoria">
                    ↵
                </a>

                <div class="article-split">

                    <div class="article-left">
                        
                        <!--Si modifica solo il percorso della foto per ora-->
                        <form method="post"
                              asp-action="ModificaFotoArticolo"
                              asp-route-id="@art.IdArticolo">

                            <!--questo input passa la ModificaFotoArticolo il nuovo percorso della foto-->
                            <input type="text" name="percorsoFoto" value="@art.Foto"/>
                            <input type="submit" name="SubmitPercorsoFoto" value="EDIT" class="btn btn-primary"/>
                        </form>
                    </div>

                    <div class="article-right">
                        <div class="article-right-content">
                            <!--questo form passa al ModificaNomeArticolo il art.IdArticolo-->
                            <form method="post"
                                  asp-action="ModificaNomeArticolo"
                                  asp-route-id="@art.IdArticolo">

                                <!--questo input passa la ModificaNomeArticolo il nuovo nome-->
                                <input type="text" name="nome" value="@art.Nome"/>
                                <!-- su css fare simile a <h1>@art.Nome</h1>-->
                                <input type="submit" name="SubmitNome" value="EDIT" class="btn btn-primary"/>
                            </form>

                            <form method="post"
                                  asp-action="ModificaDescrizioneArticolo"
                                  asp-route-id="@art.IdArticolo">
                                <textarea name="descrizione" id="txaModificaDescrizione"
                                          style="width:200px; overflow:hidden; resize:none;">@art.Descrizione</textarea>
                                <!-- su css fare simile a <p>@art.Descrizione</p>-->
                                <input type="submit" name="SubmitDescrizione" value="EDIT" class="btn btn-primary"/>
                            </form>

                            <div class="article-divider"></div>

                            <form method="post"
                                  asp-action="ModificaPrezzo_listinoArticolo"
                                  asp-route-id="@art.IdArticolo">

                                <!--gli va bene input="number" e dopo nel metodo post e' double?
                                con questo modo di fare scritto sotto ToString(InvariantCulture) forza il punto come separatore decimale
                                step="0.01" permette i decimali nell'input
                                min="0" evita prezzi negativi-->
                                <input type="number"
                                       name="prezzo_listino"
                                       value="@art.Prezzo.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                       step="0.01"
                                       min="0"/>

                                <!-- su css fare simile a <p class="prezzo">€ @art.Prezzo.ToString("0.00")</p>-->
                                <input type="submit" name="SubmitPrezzo_listino" value="EDIT" class="btn btn-primary"/>
                            </form>

                            <div class="article-divider"></div>

                            <!-- su css fare simile a <p>@art.Categoria.Nome</p>-->
                            <form method="post"
                                  asp-action="ModificaCategoriaArticolo"
                                  asp-route-id="@art.IdArticolo">
                                <select name="idcategoria" id="idcategoria">
                                    @foreach (var c in categorie)
                                    {
                                        var isSelected = c.IdCategoria == art.Categoria.IdCategoria;
                                        <option value="@c.IdCategoria" selected="@(isSelected ? "selected" : "")">
                                            @c.Nome
                                        </option>
                                    }
                                </select>

                                <input type="submit" name="SubmitCategoria" value="EDIT" class="btn btn-primary"/>
                            </form>
                        </div>
                    </div>
                </div>

            </div>

            <!-- DESTRA (raccomandazioni future) -->
            <div class="right-col">
                <form method="post"
                      asp-action="EliminaArticolo"
                      asp-route-id="@art.IdArticolo">
                    <input type="submit" name="SubmitElimina" value="ELIMINA" class="btn btn-primary"/>
                </form>
            </div>

        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="/cssAdmin/ModificaArticolo.css"/>
}

@section Scripts
{
    <!--script per adattare la larghezza della <textarea> dells descrizione-->
    <script>
        const ta = document.getElementById("txaModificaDescrizione");
        ta.style.height = ta.scrollHeight + "px";
        ta.addEventListener("input", () => {
            ta.style.height = "auto";
            ta.style.height = ta.scrollHeight + "px";
        });
    </script>
}
