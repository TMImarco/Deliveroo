@model Deliveroo.Models.HomeViewModel
@{
    ViewData["Title"] = Model.Utente != null ? Model.Utente.Nome : "Home";
    Layout = "_Layout";
}

<!-- ── HERO ───────────────────────────────────────────────── -->
<div class="idx-hero">
    <div class="idx-hero-left">
        <div class="idx-tag">
            <span class="idx-tag-dot"></span>
            Ordina ora
        </div>
        <h1 class="idx-title">
            Cosa vuoi<br><strong>mangiare?</strong>
        </h1>
    </div>

    @if (Model.Utente != null)
    {
        <div class="idx-greeting">
            <p class="idx-greeting-label">Bentornato</p>
            <p class="idx-greeting-name">@Model.Utente.Nome</p>
        </div>
    }
</div>

<!-- ── GRIGLIA CATEGORIE ──────────────────────────────────── -->
<div class="idx-section">
    <div class="idx-grid">
        @foreach (var categoria in Model.Categorie)
        {
            <a asp-controller="Articoli"
               asp-action="Articoli"
               asp-route-idCategoria="@categoria.IdCategoria"
               class="idx-card">

                <!-- FOTO -->
                <div class="idx-img-wrap">
                    <img src="@categoria.ImageUrl"
                         alt="@categoria.Nome"
                         class="idx-img"
                         loading="lazy" />
                    <div class="idx-img-overlay"></div>
                </div>

                <!-- NOME + BARRA -->
                <div class="idx-info">
                    <span class="idx-name">@categoria.Nome</span>
                    <div class="idx-bar">
                        <div class="idx-bar-fill"></div>
                    </div>
                </div>

            </a>
        }
    </div>
</div>

<!-- ── CARRELLO ───────────────────────────────────────────── -->
<a asp-controller="Carrello" asp-action="Carrello" class="cart-fab" title="Carrello">
    🛒
    <span class="cart-badge"></span>
</a>

@section Styles {
    <link rel="stylesheet" href="/css/Index.css" />
}
