@model Deliveroo.AdminViewModels.DettaglioOrdineViewModel
@{
    ViewData["Title"] = "Admin - Dettaglio Ordine #" + Model.Ordine.IdOrdine;
    Layout = "_LayoutAdmin";
    ViewData["HideSearchUser"] = true;
}

@section NavbarLinks { <!--Attiva la nav bar--> }

<!-- ── HERO ──────────────────────────────────────────────────── -->

<div class="adm-hero">
    <div class="adm-hero__left">
        <span class="adm-eyebrow">Ordini</span>
        <h1 class="adm-title">Ordine <strong>#@Model.Ordine.IdOrdine</strong></h1>
    </div>
</div>


<!-- ── PAGINA ─────────────────────────────────────────────────── -->
<div class="adm-detail-page">

    <div class="container">
        <!-- METRICS -->
        <div class="adm-metrics-row">
            <div class="adm-metric">
                <span class="adm-metric__label">Ordine</span>
                <span class="adm-metric__value">#@Model.Ordine.IdOrdine</span>
            </div>
            <div class="adm-metric">
                <span class="adm-metric__label">Importo totale</span>
                <span class="adm-metric__value">€ @Model.Ordine.ImportoTotale.ToString("0.00")</span>
            </div>
            <div class="adm-metric">
                <span class="adm-metric__label">Data ordine</span>
                <span
                    class="adm-metric__value adm-metric__value--sm">@Model.Ordine.Data.ToString("dd/MM/yyyy — HH:mm")</span>
            </div>
        </div>

        <div class="adm-detail-grid">

            <!-- CARD CLIENTE -->
            <div class="adm-card">
                <div class="adm-card__head">
                    <span class="adm-card__title">Informazioni cliente</span>
                    <a class="adm-btn adm-btn--primary adm-btn--sm"
                       asp-controller="UtentiAdmin"
                       asp-action="DettaglioUtenteAdmin"
                       asp-route-id="@Model.Utente.Id">
                        Profilo utente ›
                    </a>
                </div>
                <div class="adm-card__body">
                    <div class="adm-info-row">
                        <span class="adm-info-label">ID</span>
                        <span class="adm-info-value">#@Model.Utente.Id</span>
                    </div>
                    <div class="adm-info-row">
                        <span class="adm-info-label">Nome</span>
                        <span class="adm-info-value">@Model.Ordine.NomeCliente</span>
                    </div>
                    <div class="adm-info-row">
                        <span class="adm-info-label">Telefono</span>
                        <span class="adm-info-value">@Model.Ordine.Telefono</span>
                    </div>
                    <div class="adm-info-row">
                        <span class="adm-info-label">Indirizzo</span>
                        <span class="adm-info-value">@Model.Ordine.Indirizzo</span>
                    </div>
                </div>
            </div>

            <!-- CARD ARTICOLI -->
            <div class="adm-card">
                <div class="adm-card__head">
                    <span class="adm-card__title">Articoli ordinati</span>
                    <span class="adm-badge adm-badge--teal">@Model.Righe.Count() articoli</span>
                </div>
                <div class="adm-card__body">
                    <div class="adm-food-header">
                        <span class="adm-food-name">Articolo</span>
                        <span class="adm-food-qty">Qtà</span>
                        <span class="adm-food-price">Prezzo unit.</span>
                        <span class="adm-food-sub">Subtotale</span>
                    </div>

                    @foreach (var r in Model.Righe)
                    {
                        <div class="adm-food-row">
                            <span class="adm-food-name">@r.NomeArticolo</span>
                            <span class="adm-food-qty">× @r.Quantita</span>
                            <span class="adm-food-price">€ @((r.Prezzo / r.Quantita).ToString("0.00"))</span>
                            <span class="adm-food-sub">€ @r.Prezzo.ToString("0.00")</span>
                        </div>
                    }

                    <div class="adm-totale-row">
                        <span class="adm-totale-label">Totale ordine</span>
                        <span class="adm-totale-value">€ @Model.Ordine.ImportoTotale.ToString("0.00")</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>


@section Styles {
    <link rel="stylesheet" href="~/cssAdmin/AdminPanel.css"/>
    <style>
        /* ── CENTRA IL CONTENUTO DELLA PAGINA ──────────────────── */
        .adm-detail-page {
            max-width: 960px;
            margin-left: auto;
            margin-right: auto;
        }

        /* adm-detail-grid ha max-width:780px in AdminPanel.css      */
        /* ma senza margin:auto — il contenuto restava a sinistra    */
        .adm-detail-grid {
            max-width: 100%;
            margin-left: auto;
            margin-right: auto;
        }
    </style>
}
