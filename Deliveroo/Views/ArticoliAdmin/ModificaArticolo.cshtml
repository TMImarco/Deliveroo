@using System.Globalization
@using Deliveroo.Tabelle
@{
    ViewData["Title"] = "Admin - Modifica Articolo";
    ViewData["HideSearchUser"] = true;
    Layout = "_LayoutAdmin";

    Articolo art         = Model.ArticoloScelto;
    List<Categoria> categorie = Model.ListaCategorie;

    var currentCategoria = ViewContext.RouteData.Values["categoria"]?.ToString()
                           ?? Context.Request.Query["categoria"].ToString();
}

@section NavbarLinks {
    
    @foreach (var cat in categorie)
    {
        var isActive = currentCategoria == cat.Nome ? "active" : "";
        <a class="art-tab @isActive"
           asp-controller="ArticoliAdmin"
           asp-action="ArticoliAdmin"
           asp-route-idCategoria="@cat.IdCategoria">@cat.Nome</a>
    }
}

<!-- ── HERO ──────────────────────────────────────────────────── -->
<div class="adm-hero">
    <div class="adm-hero__left">
        <span class="adm-eyebrow">Articoli</span>
        <h1 class="adm-title">Modifica <strong>@art.Nome</strong></h1>
    </div>
    <div class="adm-hero__right">
        <!-- Elimina articolo -->
        <a href="@Url.Action("EliminaArticolo", new { id = art.IdArticolo })"
           class="adm-btn adm-btn--danger confirm-action"
           data-msg="Eliminare @art.Nome?">
            🗑 Elimina
        </a>
    </div>
</div>

<!-- ── PAGINA ─────────────────────────────────────────────────── -->
<div class="adm-form-page">
    <div class="adm-form-grid">

        <!-- COLONNA SINISTRA -->
        <div>

            <!-- FRECCE PREV / NEXT -->
            <div class="article-nav">
                @if (ViewBag.IdPrev != null)
                {
                    <a class="nav-arrow prev" asp-action="ModificaArticolo" asp-route-id="@ViewBag.IdPrev" title="Articolo precedente">&#8592;</a>
                }
                else
                {
                    <span class="nav-arrow prev disabled">&#8592;</span>
                }
                @if (ViewBag.IdNext != null)
                {
                    <a class="nav-arrow next" asp-action="ModificaArticolo" asp-route-id="@ViewBag.IdNext" title="Articolo successivo">&#8594;</a>
                }
                else
                {
                    <span class="nav-arrow next disabled">&#8594;</span>
                }
            </div>

            <form id="ModificaArticoloFormUpload"
                  method="post"
                  asp-action="ModificaArticolo"
                  asp-route-id="@art.IdArticolo"
                  enctype="multipart/form-data">

                <div class="adm-article-split">

                    <!-- ── COLONNA IMMAGINE ──────────────────── -->
                    <div class="adm-article-img-col">

                        <div class="adm-file-wrap">
                            <span class="adm-file-label">Sostituisci immagine</span>
                            <div class="adm-file-input-row">
                                <input type="file" name="ImageUrl" id="inputImage" class="adm-file" accept="image/*" />
                                <button type="button" class="adm-btn adm-btn--secondary adm-btn--sm" id="btnResetImage" disabled>
                                    Ripristina
                                </button>
                            </div>
                        </div>

                        <button type="button" id="btnSfogliaCloud" class="adm-btn adm-btn--secondary adm-btn--sm">
                            📂 Scegli da Cloudinary
                        </button>

                        <input type="hidden" name="CloudinaryImageUrl" id="hiddenImageUrl" />

                        <img src="@art.ImageUrl"
                             id="previewImage"
                             alt="Immagine articolo"
                             class="adm-article-preview visible" />

                        <input type="hidden" name="ResetImage" id="ResetImage" value="false" />
                    </div>

                    <!-- ── COLONNA CAMPI ─────────────────────── -->
                    <div class="adm-article-fields-col">
                        <div class="adm-article-fields-inner">

                            <!-- Nome -->
                            <div class="adm-field-group">
                                <label class="adm-field-label">Nome</label>
                                <div class="adm-field-edit">
                                    <input type="text" value="@art.Nome" disabled id="inputNome" class="adm-input" />
                                    <input type="hidden" name="Nome" id="hiddenNome" value="@art.Nome" />
                                    <button type="button" class="adm-edit-btn" data-target="inputNome" data-type="text" title="Modifica">✏️</button>
                                </div>
                            </div>

                            <!-- Descrizione -->
                            <div class="adm-field-group">
                                <label class="adm-field-label">Descrizione</label>
                                <div class="adm-field-edit">
                                    <textarea disabled id="txaModificaDescrizione" class="adm-textarea">@art.Descrizione</textarea>
                                    <input type="hidden" name="Descrizione" id="hiddenDescrizione" value="@art.Descrizione" />
                                    <button type="button" class="adm-edit-btn" data-target="txaModificaDescrizione" data-type="textarea" title="Modifica">✏️</button>
                                </div>
                            </div>

                            <div class="adm-divider"></div>

                            <!-- Prezzo -->
                            <div class="adm-field-group">
                                <label class="adm-field-label">Prezzo (€)</label>
                                <div class="adm-field-edit">
                                    <input type="text" value="@art.Prezzo.ToString(CultureInfo.CurrentCulture)" disabled id="inputPrezzo" class="adm-input" inputmode="decimal" />
                                    <input type="hidden" name="Prezzo" id="hiddenPrezzo" value="@art.Prezzo.ToString(CultureInfo.CurrentCulture)" />
                                    <button type="button" class="adm-edit-btn" data-target="inputPrezzo" data-type="text" title="Modifica">✏️</button>
                                </div>
                            </div>

                            <div class="adm-divider"></div>

                            <!-- Categoria -->
                            <div class="adm-field-group">
                                <label class="adm-field-label">Categoria</label>
                                <div class="adm-field-edit">
                                    <select id="selectCategoria" class="adm-select" disabled>
                                        @foreach (var c in categorie)
                                        {
                                            <option value="@c.IdCategoria" selected="@(c.IdCategoria == art.Categoria.IdCategoria ? "selected" : null)">
                                                @c.Nome
                                            </option>
                                        }
                                    </select>
                                    <input type="hidden" name="IdCategoria" id="hiddenCategoria" value="@art.Categoria.IdCategoria" />
                                    <button type="button" class="adm-edit-btn" data-target="selectCategoria" data-type="select" title="Modifica">✏️</button>
                                </div>
                            </div>

                        </div>

                        <input type="submit" value="Salva modifiche" class="adm-submit-btn" />
                    </div>

                </div>
            </form>
        </div>

        <!-- COLONNA DESTRA: info articolo -->
        <div class="adm-side-col">
            <div class="adm-side-card">
                <div class="adm-card__head">
                    <span class="adm-card__title">Dettagli</span>
                </div>
                <div class="adm-side-card__body">
                    <div class="adm-info-row">
                        <span class="adm-info-label">ID</span>
                        <span class="adm-info-value">#@art.IdArticolo</span>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- LOADING OVERLAY -->
<div id="ModificaArticoloLoadingOverlay" class="adm-loading-overlay">
    <div class="adm-spinner"></div>
    <p>Caricamento in corso…</p>
</div>

<!-- MODALE CLOUDINARY -->
<div id="cloudModal" class="adm-cloud-modal" style="display:none">
    <div class="adm-cloud-modal-box">
        <div class="adm-cloud-modal-head">
            <span>Scegli un'immagine da Cloudinary</span>
            <button type="button" id="btnChiudiModal" class="adm-btn adm-btn--secondary adm-btn--sm">✕</button>
        </div>
        <div id="cloudGallery" class="adm-cloud-gallery">
            <p style="color:var(--muted); font-size:.82rem;">Caricamento…</p>
        </div>
    </div>
</div>

<!-- MODALE CONFERMA ELIMINA -->
<div id="confirm-modal" class="adm-modal-overlay" style="display:none">
    <div class="adm-modal-box">
        <p id="modal-msg"></p>
        <div class="adm-modal-btns">
            <button id="modal-cancel"  class="adm-btn adm-btn--secondary">Annulla</button>
            <button id="modal-confirm" class="adm-btn adm-btn--danger">Elimina</button>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/cssAdmin/AdminPanel.css" />
    <link rel="stylesheet" href="/cssAdmin/ModificaArticolo.css"/>
    <link rel="stylesheet" href="/css/site.css"/>
}

@section Scripts {
    <script>
        // Loading overlay
        document.getElementById("ModificaArticoloFormUpload").addEventListener("submit", () => {
            document.getElementById("ModificaArticoloLoadingOverlay").style.display = "flex";
        });
    </script>

    <script>
        // Textarea autoresize
        const ta = document.getElementById("txaModificaDescrizione");
        ta.style.height = ta.scrollHeight + "px";
        ta.addEventListener("input", () => { ta.style.height = "auto"; ta.style.height = ta.scrollHeight + "px"; });
    </script>

    <script>
        // Conferma elimina
        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('confirm-modal');
            const modalMsg = document.getElementById('modal-msg');
            const btnConfirm = document.getElementById('modal-confirm');
            const btnCancel  = document.getElementById('modal-cancel');
            let pendingUrl = null;

            document.querySelectorAll('.confirm-action').forEach(el => {
                el.addEventListener('click', e => {
                    e.preventDefault();
                    pendingUrl = el.getAttribute('href');
                    modalMsg.textContent = el.getAttribute('data-msg');
                    modal.style.display = 'flex';
                });
            });

            btnConfirm.addEventListener('click', () => { if (pendingUrl) window.location.href = pendingUrl; });
            btnCancel.addEventListener('click',  () => { modal.style.display = 'none'; pendingUrl = null; });
            modal.addEventListener('click', e => { if (e.target === modal) { modal.style.display = 'none'; pendingUrl = null; } });
        });
    </script>

    <script>
        // Abilita edit
        document.querySelectorAll('.adm-edit-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const el = document.getElementById(btn.getAttribute('data-target'));
                el.disabled = false;
                el.focus();
                el.classList.add('active-edit');
            });
        });
    </script>

    <script>
        // Sync inputs → hidden
        const syncPairs = [
            ['inputNome',             'hiddenNome'],
            ['txaModificaDescrizione','hiddenDescrizione'],
        ];
        syncPairs.forEach(([srcId, dstId]) => {
            const src = document.getElementById(srcId);
            const dst = document.getElementById(dstId);
            if (src) src.addEventListener('input', () => dst.value = src.value);
        });

        const inputPrezzo = document.getElementById("inputPrezzo");
        const hiddenPrezzo = document.getElementById("hiddenPrezzo");
        if (inputPrezzo) inputPrezzo.addEventListener("input", () => hiddenPrezzo.value = inputPrezzo.value.replace(",", "."));

        const select = document.getElementById("selectCategoria");
        const hidden = document.getElementById("hiddenCategoria");
        if (select) select.addEventListener("change", () => hidden.value = select.value);
    </script>

    <script>
        // Preview immagine + ripristina
        const input      = document.getElementById("inputImage");
        const preview    = document.getElementById("previewImage");
        const resetBtn   = document.getElementById("btnResetImage");
        const resetFlag  = document.getElementById("ResetImage");
        const originalSrc = preview.src;

        input.addEventListener("change", function () {
            const file = this.files[0];
            if (file) {
                preview.src = URL.createObjectURL(file);
                preview.classList.add("visible");
                resetFlag.value = "false";
                resetBtn.disabled = false;
            }
        });

        resetBtn.addEventListener("click", () => {
            preview.src = originalSrc;
            input.value  = "";
            resetFlag.value = "true";
            resetBtn.disabled = true;
        });
    </script>

    <script>
        // Galleria Cloudinary
        const btnSfogliaCloud  = document.getElementById("btnSfogliaCloud");
        const cloudModal       = document.getElementById("cloudModal");
        const btnChiudiModal   = document.getElementById("btnChiudiModal");
        const cloudGallery     = document.getElementById("cloudGallery");
        const hiddenImageUrl   = document.getElementById("hiddenImageUrl");

        btnSfogliaCloud.addEventListener("click", async () => {
            cloudModal.style.display = "flex";
            cloudGallery.innerHTML   = "<p style='color:var(--muted);font-size:.82rem;grid-column:1/-1;'>Caricamento…</p>";
            try {
                const res      = await fetch("/ArticoliAdmin/GetImmaginiCloud");
                const immagini = await res.json();
                cloudGallery.innerHTML = "";
                immagini.forEach(img => {
                    const el = document.createElement("img");
                    el.src   = img.thumbUrl;
                    el.alt   = img.publicId;
                    el.classList.add("cloud-thumb");
                    el.addEventListener("click", () => {
                        preview.src            = img.url;
                        hiddenImageUrl.value   = img.url;
                        resetFlag.value        = "false";
                        resetBtn.disabled      = false;
                        cloudModal.style.display = "none";
                    });
                    cloudGallery.appendChild(el);
                });
            } catch { cloudGallery.innerHTML = "<p style='color:var(--danger);'>Errore nel caricamento.</p>"; }
        });

        btnChiudiModal.addEventListener("click", () => cloudModal.style.display = "none");
        cloudModal.addEventListener("click", e => { if (e.target === cloudModal) cloudModal.style.display = "none"; });
    </script>
}
