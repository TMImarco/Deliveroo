@using System.Globalization
@using Deliveroo.Tabelle
@{
    ViewData["Title"] = "Admin - Modifica Articoli";
    Layout = "_LayoutAdmin";

    Articolo art = Model.ArticoloScelto;
    List<Categoria> categorie = Model.ListaCategorie;
}

<h1>MODIFICA L'ARTICOLO</h1>

<div class="macro-section">
    <div class="container">
        <div class="page-split">

            <!-- SINISTRA -->
            <div class="left-col">

                <!-- NAVIGAZIONE PREV / NEXT 
                Piuttosto di ritornare sempre alla pagina di tutti gli articoli, ci sono i bottoni avanti e indietro per navigare facilmente -->
                <div class="article-nav">
                    @if (ViewBag.IdPrev != null)
                    {
                        <a class="nav-arrow prev" asp-action="ModificaArticolo"
                           asp-route-id="@ViewBag.IdPrev">&#8592;</a>
                    }
                    else
                    {
                        <span class="nav-arrow prev disabled">&#8592;</span>
                    }

                    @if (ViewBag.IdNext != null)
                    {
                        <a class="nav-arrow next" asp-action="ModificaArticolo"
                           asp-route-id="@ViewBag.IdNext">&#8594;</a>
                    }
                    else
                    {
                        <span class="nav-arrow next disabled">&#8594;</span>
                    }
                </div>

                <!-- BOTTONE BACK -->
                <a class="nav-arrow back-btn"
                   asp-action="ArticoliAdmin"
                   asp-route-idCategoria="@art.Categoria.IdCategoria">
                    ↵
                </a>
                <form id="ModificaArticoloFormUpload"
                      method="post"
                      asp-action="ModificaArticolo"
                      asp-route-id="@art.IdArticolo"
                      enctype="multipart/form-data">
                    <div class="article-split">

                        <!--Riquadro a sinistra-->
                        <div class="article-left">

                            <!--Modifica immagine-->
                            <div class="d-flex align-items-center gap-2">
                                <input type="file"
                                       name="ImageUrl"
                                       id="inputImage"/>
                                <button type="button"
                                        class="btn btn-primary"
                                        id="btnResetImage">RIPRISTINA
                                </button>
                            </div>
                            <img src="@art.ImageUrl"
                                 id="previewImage"
                                 alt="Immagine articolo"/>

                            <!-- flag per il backend -->
                            <input type="hidden" name="ResetImage" id="ResetImage" value="false"/>
                        </div>

                        <!--Riquadro a destra-->
                        <div class="article-right">

                            <div class="article-right-content">


                                <!--Modifica nome-->
                                <div class="field-edit">
                                    <input type="text"
                                           name="Nome"
                                           value="@art.Nome"
                                           readonly
                                           id="inputNome"/>

                                    <button type="button"
                                            class="edit-btn"
                                            data-target="inputNome">
                                        ✏️
                                    </button>
                                </div>

                                <!--Modifica descrizione-->
                                <div class="field-edit">
                                <textarea name="Descrizione"
                                          id="txaModificaDescrizione"
                                          style="width:200px; overflow:hidden; resize:none;"
                                          readonly>@art.Descrizione</textarea>
                                    <button type="button"
                                            class="edit-btn"
                                            data-target="txaModificaDescrizione">
                                        ✏️
                                    </button>
                                </div>

                                <div class="article-divider"></div>

                                <!--Input prezzo-->
                                <div class="field-edit">
                                    <input type="number"
                                           name="Prezzo"
                                           value="@art.Prezzo.ToString(CultureInfo.InvariantCulture)"
                                           step="0.01"
                                           min="0"
                                           readonly
                                           id="inputPrezzo"/>
                                    <button type="button"
                                            class="edit-btn"
                                            data-target="inputPrezzo">
                                        ✏️
                                    </button>
                                </div>

                                <div class="article-divider"></div>

                                <!--Input categoria-->
                                <div class="field-edit">
                                    <select id="selectCategoria" disabled>
                                        @foreach (var c in categorie)
                                        {
                                            var isSelected = c.IdCategoria == art.Categoria.IdCategoria;
                                            <option value="@c.IdCategoria" selected="@(isSelected ? "selected" : "")">
                                                @c.Nome
                                            </option>
                                        }
                                    </select>
                                    <!-- valore reale inviato -->
                                    <input type="hidden" name="IdCategoria" value="@art.Categoria.IdCategoria"
                                           id="hiddenCategoria"/>
                                    <button type="button"
                                            class="edit-btn"
                                            data-target="selectCategoria"
                                            data-type="select">
                                        ✏️
                                    </button>
                                </div>

                            </div>
                            <!--Pulsante salva modifiche finale-->
                            <input type="submit"
                                   value="SALVA MODIFICHE"
                                   class="add-btn"/>
                        </div>
                    </div>
                </form>
            </div>

            <!--A destra dell'articolo-->
            <div class="right-col">

                <!--Pulsante elimina articolo-->
                <a href="@Url.Action("EliminaArticolo", new { id = art.IdArticolo })"
                   class="btn btn-primary confirm-action"
                   data-msg="Rimuovere @art.Nome dal carrello?">ELIMINA</a>
            </div>
        </div>
    </div>
</div>

<!--Overlay per caricamento-->
<div id="ModificaArticoloLoadingOverlay" class="overlay">
    <div class="spinner"></div>
    <p>Caricamento in corso...</p>
</div>

<!-- POP-UP per la conferma di ELIMINAZIONE -->
<div id="confirm-modal" class="modal-overlay" style="display:none">
    <div class="modal-box">
        <p id="modal-msg"></p>
        <div class="modal-btns">
            <button id="modal-cancel" class="modal-btn cancel">Annulla</button>
            <button id="modal-confirm" class="modal-btn confirm">Conferma</button>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="/cssAdmin/ModificaArticolo.css"/>
}

@section Scripts
{
    <!--Script per la overlay del caricamento-->
    <script>
        document.getElementById("ModificaArticoloFormUpload").addEventListener("submit", function () {
            document.getElementById("ModificaArticoloLoadingOverlay").style.display = "flex";
        });
    </script>

    <!--script per adattare la larghezza della <textarea> della descrizione-->
    <script>
        const ta = document.getElementById("txaModificaDescrizione");
        ta.style.height = ta.scrollHeight + "px";
        ta.addEventListener("input", () => {
            ta.style.height = "auto";
            ta.style.height = ta.scrollHeight + "px";
        });
    </script>

    <!--Script per il pop up quando ELIMINI l'articolo-->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('confirm-modal');
            const modalMsg = document.getElementById('modal-msg');
            const btnConfirm = document.getElementById('modal-confirm');
            const btnCancel = document.getElementById('modal-cancel');
            let pendingUrl = null;

            document.querySelectorAll('.confirm-action').forEach(el => {
                el.addEventListener('click', e => {
                    e.preventDefault();
                    pendingUrl = el.getAttribute('href');
                    modalMsg.textContent = el.getAttribute('data-msg');
                    modal.style.display = 'flex';
                });
            });

            btnConfirm.addEventListener('click', () => {
                if (pendingUrl) window.location.href = pendingUrl;
            });

            btnCancel.addEventListener('click', () => {
                modal.style.display = 'none';
                pendingUrl = null;
            });

            modal.addEventListener('click', e => {
                if (e.target === modal) {
                    modal.style.display = 'none';
                    pendingUrl = null;
                }
            });
        });
    </script>

    <!--Script per abilitare la modifica degli input-->
    <script>
        document.querySelectorAll('.edit-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const targetId = btn.getAttribute('data-target');
                const type = btn.getAttribute('data-type');
                const el = document.getElementById(targetId);

                if (type === "select" || type === "file") {
                    el.disabled = false;
                } else {
                    el.readOnly = false;
                }

                el.focus();
                el.classList.add('active-edit');
            });
        });
    </script>

    <!--Script per la gestione del select idCategoria-->
    <script>
        const select = document.getElementById("selectCategoria");
        const hidden = document.getElementById("hiddenCategoria");

        if (select) {
            select.addEventListener("change", () => {
                hidden.value = select.value;
            });
        }
    </script>

    <!--Script per preview immagine caricata e ripristina immagine (da immagine caricata lo ripristina a immagine già nel db-->
    <script>
        const input = document.getElementById("inputImage");
        const preview = document.getElementById("previewImage");
        const resetBtn = document.getElementById("btnResetImage");
        const resetFlag = document.getElementById("ResetImage");

        const originalImage = preview.src;

        input.addEventListener("change", function () {
            const file = this.files[0];

            if (file) {
                preview.src = URL.createObjectURL(file);
                resetFlag.value = "false";
            }
        });

        resetBtn.addEventListener("click", function () {
            preview.src = originalImage;
            input.value = "";
            resetFlag.value = "true";
        });
    </script>
}
