@{
    ViewData["Title"] = "Admin - Aggiungi Articolo";
    ViewData["HideSearchUser"] = true;
    Layout = "_LayoutAdmin";
    @model List<Deliveroo.Tabelle.Categoria>
}

@section NavbarLinks {
    <!--Attiva la nav bar-->
}

<!-- ── HERO ──────────────────────────────────────────────────── -->
<div class="adm-hero">
    <div class="adm-hero__left">
        <span class="adm-eyebrow">Articoli</span>
        <h1 class="adm-title">Aggiungi <strong>nuovo articolo</strong></h1>
    </div>
</div>

<!-- ── PAGINA ─────────────────────────────────────────────────── -->
<div class="adm-form-page">
    <div class="adm-form-grid">

        <!-- COLONNA SINISTRA: FORM -->
        <div>
            <form id="AggiungiNuovoArticoloFormUpload"
                  method="post"
                  asp-action="AggiungiNuovoArticolo"
                  enctype="multipart/form-data">

                <div class="adm-article-split">

                    <!-- ── COLONNA IMMAGINE ──────────────────── -->
                    <div class="adm-article-img-col">
                        <div class="adm-file-wrap">
                            <span class="adm-file-label">Foto articolo</span>
                            <input type="file"
                                   id="UrlFoto"
                                   name="UrlFoto"
                                   class="adm-file"
                                   accept="image/*"
                                   required />
                        </div>

                        <!-- placeholder mostrato finché nessuna immagine -->
                        <div class="adm-article-img-placeholder" id="imgPlaceholder">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/>
                                <path d="M21 15l-5-5L5 21"/>
                            </svg>
                            <span>Nessuna immagine selezionata</span>
                        </div>

                        <img id="previewImage"
                             src="#"
                             alt="Anteprima"
                             class="adm-article-preview" />
                    </div>

                    <!-- ── COLONNA CAMPI ─────────────────────── -->
                    <div class="adm-article-fields-col">
                        <div class="adm-article-fields-inner">

                            <div class="adm-field-group">
                                <label class="adm-field-label" for="nome">Nome</label>
                                <input type="text"
                                       id="nome"
                                       name="nome"
                                       class="adm-input"
                                       placeholder="Es. Margherita"
                                       required />
                            </div>

                            <div class="adm-field-group">
                                <label class="adm-field-label" for="descrizione">Descrizione</label>
                                <textarea id="descrizione"
                                          name="descrizione"
                                          class="adm-textarea"
                                          placeholder="Descrizione breve dell'articolo…"
                                          required></textarea>
                            </div>

                            <div class="adm-divider"></div>

                            <div class="adm-field-group">
                                <label class="adm-field-label" for="prezzo">Prezzo (€)</label>
                                <input type="number"
                                       id="prezzo"
                                       name="prezzo"
                                       class="adm-input"
                                       step="0.01"
                                       min="0"
                                       placeholder="0.00"
                                       required />
                            </div>

                            <div class="adm-divider"></div>

                            <div class="adm-field-group">
                                <label class="adm-field-label" for="idcategoria">Categoria</label>
                                <select id="idcategoria"
                                        name="idcategoria"
                                        class="adm-select"
                                        required>
                                    <option value="">Seleziona categoria…</option>
                                    @foreach (var c in Model)
                                    {
                                        <option value="@c.IdCategoria">@c.Nome</option>
                                    }
                                </select>
                            </div>

                        </div>

                        <input type="submit"
                               value="Aggiungi articolo"
                               class="adm-submit-btn" />
                    </div>

                </div>
            </form>
        </div>

        <!-- COLONNA DESTRA: info/tips -->
        <div class="adm-side-col">
            <div class="adm-side-card">
                <div class="adm-card__head">
                    <span class="adm-card__title">Suggerimenti</span>
                </div>
                <div class="adm-side-card__body" style="font-size:.82rem; color:var(--muted); line-height:1.6;">
                    <p>• Carica un'immagine in formato JPG o PNG, preferibilmente quadrata.</p>
                    <p>• Il nome deve essere breve e riconoscibile.</p>
                    <p>• La descrizione appare nella scheda prodotto, tienila concisa.</p>
                    <p>• Il prezzo accetta due decimali (es. 9.90).</p>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- LOADING OVERLAY -->
<div id="aggiungiNuovoArticoloLoadingOverlay" class="adm-loading-overlay">
    <div class="adm-spinner"></div>
    <p>Caricamento in corso…</p>
</div>

@section Styles {
    <link rel="stylesheet" href="~/cssAdmin/AdminPanel.css" />
}

@section Scripts {
    <script>
        document.getElementById("AggiungiNuovoArticoloFormUpload").addEventListener("submit", function () {
            document.getElementById("aggiungiNuovoArticoloLoadingOverlay").style.display = "flex";
        });
    </script>

    <script>
        const inputFile   = document.getElementById("UrlFoto");
        const preview     = document.getElementById("previewImage");
        const placeholder = document.getElementById("imgPlaceholder");

        inputFile.addEventListener("change", function () {
            const file = this.files[0];
            if (file) {
                preview.src = URL.createObjectURL(file);
                preview.classList.add("visible");
                placeholder.style.display = "none";
            }
        });
    </script>

    <script>
        const ta = document.getElementById("descrizione");
        ta.style.height = ta.scrollHeight + "px";
        ta.addEventListener("input", () => {
            ta.style.height = "auto";
            ta.style.height = ta.scrollHeight + "px";
        });
    </script>
}
