@model Deliveroo.AdminViewModels.IndexAdminViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_LayoutAdmin";
}

<!-- ── HERO ──────────────────────────────────────────────────── -->
<div class="adm-hero">
    <div class="adm-hero__left">
        <span class="adm-eyebrow">Pannello di controllo</span>
        <h1 class="adm-title">Dashboard <strong>Admin</strong></h1>
    </div>
    <div class="adm-hero__right">
        <span class="adm-badge adm-badge--teal">Live</span>
    </div>
</div>

<!-- ── PAGINA ─────────────────────────────────────────────────── -->
<div class="adm-page">
    <!-- DASHBOARD GRID -->
    <div class="adm-dashboard-grid">

        <!-- ① GRAFICO CATEGORIE -->
        <div class="adm-card">
            <div class="adm-card__head">
                <span class="adm-card__title">Categorie più ordinate</span>
            </div>
            <div class="adm-card__body" style="display:flex; justify-content:center; align-items:center; min-height:280px;">
                <canvas id="graficoCategorie" style="max-width:500px; max-height:500px;"></canvas>
            </div>
        </div>

        <!-- ② BEST SELLING -->
        <div class="adm-card">
            <div class="adm-card__head">
                <span class="adm-card__title">Best selling</span>
                <!-- controllo numero classificati inline -->
                <form method="post" asp-action="IndexAdmin" style="display:inline-flex; align-items:center; gap:.5rem;">
                    <div class="adm-ranking-ctrl">
                        <label for="numeroTotaleClassificati">Top</label>
                        <input type="number"
                               id="numeroTotaleClassificati"
                               name="numeroTotaleClassificati"
                               value="@Model.NumeroTotaleClassificati"
                               min="3"
                               step="1"
                               onchange="this.form.submit()" />
                    </div>
                    @if (Model.NumeroTotaleClassificati < 3 || Model.isMinore)
                    {
                        <span class="adm-ranking-warn">min 3</span>
                    }
                </form>
            </div>
            <div class="adm-card__body">
                <div class="ranking-wrap">
                    @{
                        var lista   = Model.ClassificaArticoli.ToList();
                        var medals  = new[] { "🥇", "🥈", "🥉" };
                    }

                    <!-- PODIO -->
                    @if (lista.Count >= 1)
                    {
                        <div class="podium">
                            @for (int i = 0; i < Math.Min(3, lista.Count); i++)
                            {
                                var a = lista[i];
                                <div class="podium-card pos-@(i + 1)" data-id="@a.IdArticolo">
                                    <div class="podium-pos">@(i + 1)°</div>
                                    <div class="podium-medal">@medals[i]</div>
                                    <div class="podium-name">@a.Nome</div>
                                    <div class="podium-cat">@a.Categoria.Nome</div>
                                    <div class="podium-orders">@a.NumeroOrdini <span>ordini</span></div>
                                    <div class="podium-price">€ @a.Prezzo.ToString("0.00")</div>
                                </div>
                            }
                        </div>
                    }

                    <!-- LISTA -->
                    @if (lista.Count > 3)
                    {
                        <div class="rank-list">
                            @for (int i = 3; i < Math.Min(Model.NumeroTotaleClassificati, lista.Count); i++)
                            {
                                var a = lista[i];
                                <div class="rank-row" data-id="@a.IdArticolo">
                                    <div class="arank-num">#@(i + 1)</div>
                                    <div class="rank-info">
                                        <span class="rank-name">@a.Nome</span>
                                        <span class="rank-cat">@a.Categoria.Nome</span>
                                    </div>
                                    <div class="rank-price">€ @a.Prezzo.ToString("0.00")</div>
                                    <div class="rank-orders">
                                        <strong>@a.NumeroOrdini</strong>
                                        <small>ordini</small>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ③ AZIONI RAPIDE -->
        <div class="adm-card adm-card--full">
            <div class="adm-card__head">
                <span class="adm-card__title">Azioni rapide</span>
            </div>
            <div class="adm-card__body">
                <div class="adm-quick-links">
                    <a class="adm-quick-link"
                       asp-controller="CategorieAdmin" asp-action="CategorieAdmin">
                        <span class="adm-quick-link__icon">📦</span>
                        <span class="adm-quick-link__text">
                            <span class="adm-quick-link__label">Articoli</span>
                            <span class="adm-quick-link__desc">Modifica o elimina articoli esistenti</span>
                        </span>
                        <span class="adm-quick-link__arrow">›</span>
                    </a>
                    <a class="adm-quick-link"
                       asp-controller="ArticoliAdmin" asp-action="AggiungiNuovoArticolo">
                        <span class="adm-quick-link__icon">➕</span>
                        <span class="adm-quick-link__text">
                            <span class="adm-quick-link__label">Aggiungi articolo</span>
                            <span class="adm-quick-link__desc">Carica un nuovo prodotto</span>
                        </span>
                        <span class="adm-quick-link__arrow">›</span>
                    </a>
                    <a class="adm-quick-link"
                       asp-controller="AssociazioniAdmin" asp-action="AssociazioniAdmin">
                        <span class="adm-quick-link__icon">🔗</span>
                        <span class="adm-quick-link__text">
                            <span class="adm-quick-link__label">Associazioni d'acquisto</span>
                            <span class="adm-quick-link__desc">Gestisci le confidence tra articoli</span>
                        </span>
                        <span class="adm-quick-link__arrow">›</span>
                    </a>
                    <a class="adm-quick-link"
                       asp-controller="UtentiAdmin" asp-action="GestioneUtentiAdmin">
                        <span class="adm-quick-link__icon">👤</span>
                        <span class="adm-quick-link__text">
                            <span class="adm-quick-link__label">Gestione utenti</span>
                            <span class="adm-quick-link__desc">Visualizza e modifica gli utenti</span>
                        </span>
                        <span class="adm-quick-link__arrow">›</span>
                    </a>
                </div>
            </div>
        </div>

        <!-- ④ ORDINI (full width) -->
        <div class="adm-card adm-card--full">
            <div class="adm-card__head">
                <span class="adm-card__title">Ordini recenti</span>
            </div>
            <div class="adm-card__body">
                <div class="adm-table-wrap">
                    <table id="ordiniTable" class="display" style="width:100%">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nome cliente</th>
                                <th>Data</th>
                                <th>Importo</th>
                                <th>Indirizzo</th>
                                <th>Telefono</th>
                                <th>Username</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in Model.Ordini)
                            {
                                <tr>
                                    <td>@o.IdOrdine</td>
                                    <td>@o.NomeCliente</td>
                                    <td>@o.Data.ToString("dd/MM/yyyy — HH:mm")</td>
                                    <td>€ @o.ImportoTotale.ToString("0.00")</td>
                                    <td>@o.Indirizzo</td>
                                    <td>@o.Telefono</td>
                                    <td>
                                        @foreach (var u in Model.Utenti)
                                        {
                                            if (o.IdUtente == u.Id) { @u.Username; }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div><!-- /adm-dashboard-grid -->
</div><!-- /adm-page -->


@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        $(document).ready(function () {
            $('#ordiniTable').DataTable();
            $('#ordiniTable tbody').on('click', 'tr', function () {
                var id = $(this).find('td:first').text();
                window.location.href = '@Url.Action("DettaglioOrdineAdmin", "OrdiniAdmin")/' + id;
            });
        });

        document.querySelectorAll('.podium-card, .rank-row').forEach(el => {
            el.addEventListener('click', () => {
                const id = el.dataset.id;
                window.location.href = '@Url.Action("ModificaArticolo", "ArticoliAdmin")/' + id;
            });
            el.style.cursor = 'pointer';
        });
    </script>

    <script>
        @{
            List<string> cslabel = new();
            List<int>    csdata  = new();
            foreach (var d in Model.OrdiniTotaliDiOgniCategoria)
            { cslabel.AddRange(d.Keys); csdata.AddRange(d.Values); }
        }
        const labels = @Json.Serialize(cslabel);
        const data   = @Json.Serialize(csdata);
        const colors = ['#00CCBC','#36A2EB','#FFCE56','#9966FF','#FF9F40','#00C851','#FF4444','#33B5E5','#AA66CC','#FF6384'];

        new Chart(document.getElementById('graficoCategorie'), {
            type: 'doughnut',
            data: {
                labels,
                datasets: [{ label: 'Ordini totali', data, backgroundColor: colors, borderWidth: 2 }]
            },
            options: {
                plugins: {
                    legend: { labels: { font: { family: 'DM Sans', size: 12 }, color: '#3D5552' } }
                }
            }
        });
    </script>
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="~/cssAdmin/AdminPanel.css" />
    <link rel="stylesheet" href="~/cssAdmin/Classifica.css" />
}
