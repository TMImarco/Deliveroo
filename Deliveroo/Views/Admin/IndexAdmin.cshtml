@model Deliveroo.AdminViewModels.IndexAdminViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_LayoutAdmin";
}

<div class="grid-container">

    <!--BLOCCO 1 della GRID (in altro a sinistra)-->
    <!--GRAFICO-->
    <div class="container">
        <h4>CATEGORIE PIU' ORDINATE</h4>
        <canvas id="graficoCategorie"></canvas>
    </div>

    <!--BLOCCO 2 della GRID (in altro a destra)-->
    <!-- CLASSIFICA ARTICOLI -->
    <!--DA FARE: modificare che il podio sia a destra e le altre posizioni a sinistra-->
    <div class="container-fluid">
        <h4>BEST SELLING</h4>
        
        <p>Seleziona numero di classificati</p>
        <form method="post" asp-action="IndexAdmin">
            <input type="number"
                   name="numeroTotaleClassificati"
                   value="@Model.NumeroTotaleClassificati"
                   min="4"
                   step="1"
                   onchange="this.form.submit()"/>
        </form>
        
        <div class="ranking-wrapper">
            @{
                var lista = Model.ClassificaArticoli.ToList();
                var medals = new[] { "🥇", "🥈", "🥉" };
            }

            <!-- PODIO: primi 3 -->
            @if (lista.Count >= 1)
            {
                <div class="podium">
                    @for (int i = 0; i < Math.Min(3, lista.Count); i++)
                    {
                        var a = lista[i];
                        <div class="podium-card pos-@(i + 1)">
                            <div class="podium-pos">@(i + 1)</div>
                            <div class="podium-medal">@medals[i]</div>
                            <div class="podium-name">@a.Nome</div>
                            <div class="podium-category">@a.Categoria.Nome</div>
                            <div class="podium-orders">@a.NumeroOrdini <span>ordini</span></div>
                            <div class="podium-price">€ @a.Prezzo.ToString("0.00")</div>
                        </div>
                    }
                </div>
            }

            <!-- LISTA: dal 4° in poi -->
            @if (lista.Count > 3)
            {
                <div class="ranking-list">
                    @for (int i = 3; i < Math.Min(Model.NumeroTotaleClassificati, lista.Count); i++)
                    {
                        var a = lista[i];
                        <div class="rank-row">
                            <div class="rank-num">#@(i + 1)</div>
                            <div class="rank-info">
                                <span class="rank-name">@a.Nome</span>
                                <span class="rank-cat">@a.Categoria.Nome</span>
                            </div>
                            <div class="rank-price">€ @a.Prezzo.ToString("0.00")</div>
                            <div class="rank-orders">
                                <strong>@a.NumeroOrdini</strong>
                                <small>ordini</small>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!--BLOCCO 3 della GRID (in basso a sinistra)-->
    <div class="container">
        <p>
            <a asp-controller="CategorieAdmin"
               asp-action="CategorieAdmin"
               class="btn btn-primary">
                ARTICOLI (MODIFICA/ELIMINA)
            </a>
        </p>

        <p>
            <a asp-controller="ArticoliAdmin"
               asp-action="AggiungiNuovoArticolo"
               class="btn btn-primary">
                AGGIUNGI ARTICOLO
            </a>
        </p>

        <p>
            <a asp-controller="AssociazioniAdmin"
               asp-action="AssociazioniAdmin"
               class="btn btn-primary">
                ASSOCIAZIONI D'ACQUISTO
            </a>
        </p>
    </div>

    <!--BLOCCO 4 della GRID (in basso a destra)-->
    <!--ORDINI-->
    <div class="container">
        <h4>ORDINI</h4>
        <!--data table per gli ORDINI-->
        <table id="ordiniTable" 
               class="display">
            <thead>
            <tr>
                <th>ID ordine</th>
                <th>Cliente</th>
                <th>Data</th>
                <th>Importo totale</th>
                <th>Indirizzo</th>
                <th>Numero di telefono</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var o in Model.Ordini)
            {
                <tr>
                    <td>@o.IdOrdine</td>
                    <td>@o.NomeCliente</td>
                    <td>@o.Data.ToString("dd/MM/yyyy")</td>
                    <td>@o.ImportoTotale</td>
                    <td>@o.Indirizzo</td>
                    <td>@o.Telefono</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>


@section Scripts {
    <!--SCRIPT per DATA TABLE-->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <!--SCRIPT per i GRAFICI-->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!--SCRIPT per la creazione delle DATA TABLE-->
    <script>
        $(document).ready(function () {
            $('#ordiniTable').DataTable();
            $('#associazioniTable').DataTable();
            $('#classificaArticoliTable').DataTable();
        });

        $('#ordiniTable tbody').on('click', 'tr', function () {
            var id = $(this).find('td:first').text();
            window.location.href = '@Url.Action("DettaglioOrdine", "Admin")/' + id;
        });
    </script>

    <!--SCRIPT per la creazione del GRAFICO "graficoCategorie"-->
    <script>

        //blocco di codice c# per dividere tutti i dizionari
        //per poi inserire le key come label e i value come data
        //mentendo l'ordine
        @{
            List<String> cslabel = new List<string>();
            List<int> csdata = new List<int>();

            foreach (var d in Model.OrdiniTotaliDiOgniCategoria)
            {
                cslabel.AddRange(d.Keys);
                csdata.AddRange(d.Values);
            }
        }

        //serializzazione dei dati perche' la libreria accetta solo json per data e label
        const labels = @Json.Serialize(cslabel);
        const data = @Json.Serialize(csdata);

        //JSON per i colori
        const colors = [
            '#FF6384', // rosa
            '#36A2EB', // blu
            '#FFCE56', // giallo
            '#4BC0C0', // turchese
            '#9966FF', // viola
            '#FF9F40', // arancione
            '#00C851', // verde
            '#FF4444', // rosso
            '#33B5E5', // azzurro
            '#AA66CC'  // lilla
        ];

        new Chart(document.getElementById('graficoCategorie'), {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Ordini totali:',
                        data: data,
                        backgroundColor: colors,
                        borderWidth: 2
                    }]
                }
            }
        );
    </script>
}

@section Styles {
    <!--stile sheet per le data tables-->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css"/>

    <!--importazione font per alcune classi della classifica (per ora tolto)
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600&display=swap"
          rel="stylesheet">-->

    <link rel="stylesheet" href="~/cssAdmin/classifica.css"/>
    <link rel="stylesheet" href="~/cssAdmin/Index.css"/>
}