@{
    ViewData["Title"] = "Admin - Gestione Utenti";
    ViewData["HideSearchUser"] = true;
    Layout = "_LayoutAdmin";
}

@section NavbarLinks { <!--Attiva la nav bar--> }

<!-- ── HERO ──────────────────────────────────────────────────── -->
<div class="adm-hero">
    <div class="adm-hero__left">
        <span class="adm-eyebrow">Utenti</span>
        <h1 class="adm-title">Gestione <strong>utenti</strong></h1>
    </div>
    <span class="adm-badge adm-badge--muted">@Model.NumeroIscritti iscritti</span>
</div>

<!-- ── PAGINA ─────────────────────────────────────────────────── -->
<div class="adm-page">
    <div class="adm-card">
        <div class="adm-card__head">
            <span class="adm-card__title">Tutti gli utenti</span>
        </div>
        <div class="adm-card__body">
            <div class="adm-table-wrap">
                <table id="utentiTable" class="display" style="width:100%">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nome</th>
                            <th>Username</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var utente in Model.Utenti)
                        {
                            <tr>
                                <td>@utente.Id</td>
                                <td>@utente.Nome</td>
                                <td>@utente.Username</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>  

@section Styles {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="~/cssAdmin/AdminPanel.css" />
}

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#utentiTable').DataTable();
        });

        $('#utentiTable tbody').on('click', 'tr', function () {
            var id = $(this).find('td:first').text();
            window.location.href = '@Url.Action("DettaglioUtenteAdmin", "UtentiAdmin")/' + id;
        });
    </script>
}
