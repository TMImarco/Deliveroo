@model List<Deliveroo.Tabelle.Articolo>
@{
    ViewData["Title"] = "I tuoi preferiti";
    Layout = "_Layout";
}

@section NavbarLinks { }

<div class="preferiti-hero">
    <div class="preferiti-hero__inner">
        <span class="preferiti-eyebrow">La tua lista</span>
        <h1 class="preferiti-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28"
                 viewBox="0 0 24 24" fill="#e05b5b" stroke="#e05b5b"
                 stroke-width="1.5" style="vertical-align:-4px;margin-right:8px">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06
                         a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78
                         1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            Articoli preferiti
        </h1>
        <p class="preferiti-subtitle">
            @Model.Count articol@(Model.Count == 1 ? "o salvato" : "i salvati")
        </p>
    </div>
</div>

<div class="preferiti-container">

    @if (!Model.Any())
    {
        <div class="preferiti-empty">
            <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56"
                 viewBox="0 0 24 24" fill="none" stroke="#ccc"
                 stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06
                         a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78
                         1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <p>Non hai ancora salvato nessun articolo.</p>
            <a asp-controller="Home" asp-action="Index" class="btn-teal">
                Esplora il menu
            </a>
        </div>
    }
    else
    {
        <div class="preferiti-grid">
            @foreach (var art in Model)
            {
                <div class="pref-card fadeUp">
                    <a asp-controller="Articoli" asp-action="Articoli"
                       asp-route-id="@art.IdArticolo" class="pref-card__img-wrap">
                        <img src="@art.ImageUrl" alt="@art.Nome"
                             onerror="this.src='/img/placeholder.png'"/>
                    </a>

                    <div class="pref-card__body">
                        <div class="pref-card__top">
                            <a asp-controller="Articoli" asp-action="Articoli"
                               asp-route-id="@art.IdArticolo" class="pref-card__name">
                                @art.Nome
                            </a>
                            <button class="btn-preferito attivo"
                                    onclick="togglePreferito(this, @art.IdArticolo, true)"
                                    title="Rimuovi dai preferiti">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                     viewBox="0 0 24 24" fill="currentColor" stroke="currentColor"
                                     stroke-width="1.5">
                                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06
                                             a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78
                                             1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                </svg>
                            </button>
                        </div>

                        <p class="pref-card__desc">
                            @(art.Descrizione?.Length > 80
                                ? art.Descrizione[..80] + "…"
                                : art.Descrizione)
                        </p>

                        <div class="pref-card__footer">
                            <span class="pref-card__price">
                                €@art.Prezzo.ToString("F2")
                            </span>
                            <!--<div class="pref-card__stars">
                                @for (int i = 0; i < 5; i++)
                                {
                                    <span class="@(i < art.IdArticolo ? "star on" : "star")">★</span>
                                }
                            </div>-->
                            <button class="btn-teal btn-teal--sm"
                                    data-id="@art.IdArticolo">
                                Aggiungi
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- ── CARRELLO ───────────────────────────────────────────── -->
<a asp-controller="Carrello" asp-action="Carrello" class="cart-fab" title="Carrello">
    🛒
    <span class="cart-badge"></span>
</a>

@section Styles {
    <link rel="stylesheet" href="/css/Preferiti.css" />
}

@section Scripts {
<script>
function togglePreferito(btn, id, rimuoviDallaPagina = false) {
    fetch('/Articoli/TogglePreferito', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `id=${id}`
    }).then(() => {
        if (rimuoviDallaPagina) {
            const card = btn.closest('.pref-card');
            card.style.opacity = '0';
            card.style.transform = 'scale(.95)';
            card.style.transition = 'all .25s ease';
            setTimeout(() => card.remove(), 260);
        } else {
            btn.classList.toggle('attivo');
        }
    });
}

/* AGGIORNARE IL BADGE */
async function aggiornaBadge() {
    const res = await fetch('/Carrello/NumeroElementi');
    const count = await res.text();
    document.querySelectorAll('.cart-badge').forEach(b => b.textContent = count);
}
document.querySelectorAll('.btn-teal--sm').forEach(btn => {
    btn.addEventListener('click', async (e) => {
        e.stopPropagation();

        const id = btn.dataset.id;
        await fetch(`/Carrello/MettiNelCarrello?id=${id}`, {
            method: 'POST'
        });
        const toastEl = document.getElementById('toastCarrello');
        const toast = bootstrap.Toast.getOrCreateInstance(toastEl);
        toast.show();
    });
});

aggiornaBadge();
</script>
}