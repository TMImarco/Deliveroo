@using Deliveroo.Tabelle
@model Deliveroo.Models.InserimentoArticoloViewModel
@inject GestioneDati Gestione
@{
    ViewData["Title"] = "Articoli";
    Layout = "_Layout";
    Articolo art = Model.ArticoloScelto;

    var categorie = Gestione.GetTutteCategorie();
    var currentCategoria = ViewContext.RouteData.Values["categoria"]?.ToString()
                           ?? Context.Request.Query["categoria"].ToString();
}

@section NavbarLinks {
    @foreach (var cat in categorie)
    {
        var isActive = currentCategoria == cat.Nome ? "active" : "";
        <a class="art-tab @isActive"
           asp-controller="Articoli"
           asp-action="Articoli"
           asp-route-idCategoria="@cat.IdCategoria">
            @cat.Nome
        </a>
    }
}

<div class="macro-section">
    <div class="container">
        <div class="page-split">

            <!-- ── SINISTRA ─────────────────────────────── -->
            <div class="left-col">

                <!-- Frecce prev / next -->
                @if (ViewBag.IdPrev != null)
                {
                    <a class="nav-arrow prev"
                       asp-action="InserimentoArticolo"
                       asp-route-id="@ViewBag.IdPrev"
                       title="Articolo precedente">&#8592;</a>
                }
                else
                {
                    <span class="nav-arrow prev disabled">&#8592;</span>
                }

                @if (ViewBag.IdNext != null)
                {
                    <a class="nav-arrow next"
                       asp-action="InserimentoArticolo"
                       asp-route-id="@ViewBag.IdNext"
                       title="Articolo successivo">&#8594;</a>
                }
                else
                {
                    <span class="nav-arrow next disabled">&#8594;</span>
                }

                <!-- Card articolo -->
                <div class="article-split">

                    <!-- Foto -->
                    <div class="article-left">
                        <img src="@art.ImageUrl"
                             alt="@art.Nome"
                             loading="lazy" />
                    </div>

                    <!-- Dettagli -->
                    <div class="article-right">
                        <div class="article-right-content">

                            <h1>@art.Nome</h1>

                            <p class="descrizione">@art.Descrizione</p>

                            <div class="article-divider"></div>

                            <p class="prezzo">€&nbsp;@art.Prezzo.ToString("0.00")</p>

                            <div class="article-divider"></div>

                            <!-- Barra teal (coerente con idx-bar) -->
                            <div class="art-bar">
                                <div class="art-bar-fill"></div>
                            </div>

                            <!-- Quantità + cuore -->
                            <div class="qty-add-row">
                                <div class="qty-row">
                                    <button class="qty-btn" onclick="cambiaQty(-1)">−</button>
                                    <span class="qty-val" id="qty">1</span>
                                    <button class="qty-btn" onclick="cambiaQty(1)">+</button>
                                </div>

                                <button class="btn-cuore @(ViewBag.IsPreferitoAttivo ? "attivo" : "")"
                                        id="btn-preferito"
                                        title="Aggiungi ai preferiti">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06
                                                 a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78
                                                 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                    </svg>
                                </button>
                            </div>

                        </div>

                        <button id="btn-aggiungi" class="add-btn" onclick="aggiungiAlCarrello()">
                            Aggiungi al carrello
                        </button>
                    </div>
                </div>

                @section AboveNavbar {
                    <div class="total-overlay">
                        <span class="label">Totale:</span>
                        <span class="valore" id="totale">€ @art.Prezzo.ToString("0.00")</span>
                    </div>
                }

            </div>

            <!-- ── DESTRA — CONSIGLIATI ──────────────────── -->
            <div class="right-col">
                <div class="col-header">
                    <h2>Consigliati per te</h2>
                </div>

                @if (Model.Raccomandazioni != null && Model.Raccomandazioni.Any())
                {
                    <div class="rec-list">
                        @foreach (var articolo in Model.Raccomandazioni)
                        {
                            <div class="rec-row">
                                <a asp-action="InserimentoArticolo"
                                   asp-route-id="@articolo.IdArticolo"
                                   class="rec-link">
                                    <img class="rec-thumb"
                                         src="@Url.Content(articolo.ImageUrl)"
                                         alt="@articolo.Nome" />
                                    <div class="rec-info">
                                        <div class="rec-name">@articolo.Nome</div>
                                        <div class="rec-price">€&nbsp;@articolo.Prezzo.ToString("F2")</div>
                                    </div>
                                </a>

                                <button class="rec-add-btn"
                                        data-id="@articolo.IdArticolo"
                                        data-nome="@articolo.Nome"
                                        data-prezzo="@articolo.Prezzo"
                                        data-image="@articolo.ImageUrl">+</button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="padding: 1.5rem; color: var(--muted); font-size: 0.82rem;
                                text-align: center; font-family: 'DM Sans', sans-serif;">
                        Nessun consiglio disponibile
                    </div>
                }
            </div>

        </div>
    </div>
</div>

<!-- ── TOAST ──────────────────────────────────────────────── -->
<div class="toast-container position-fixed bottom-0 start-50 translate-middle-x p-3"
     style="z-index: 9999">
    <div id="toastCarrello"
         class="toast align-items-center text-white border-0"
         role="alert"
         data-bs-delay="2000">
        <div class="toast-body d-flex align-items-center gap-2">
            <span style="font-size:1.1rem">🛒</span>
            <span>Articolo aggiunto al carrello!</span>
        </div>
    </div>
</div>

<!-- ── CART FAB (identico all'Index) ─────────────────────── -->
<a asp-controller="Carrello" asp-action="Carrello" class="cart-fab" title="Carrello">
    🛒
    <span class="cart-badge"></span>
</a>

@section Styles {
    <link rel="stylesheet" href="/css/InserimentoArticolo.css" />
}

@section Scripts {
    <script>
        const prezzo      = @Model.ArticoloScelto.Prezzo.ToString(System.Globalization.CultureInfo.InvariantCulture);
        const aggiungiUrl = '@Url.Action("MettiNelCarrello", "Carrello", new { id = Model.ArticoloScelto.IdArticolo })';
        let qty = 1;

        function aggiornaTotale() {
            document.getElementById('totale').textContent =
                '€ ' + (prezzo * qty).toFixed(2);
        }

        function cambiaQty(d) {
            qty = Math.max(1, qty + d);
            document.getElementById('qty').textContent = qty;
            aggiornaTotale();
        }

        async function aggiornaBadge() {
            const res   = await fetch('/Carrello/NumeroElementi');
            const count = await res.text();
            document.querySelectorAll('.cart-badge').forEach(b => b.textContent = count);
        }

        async function aggiungiAlCarrello() {
            await fetch(aggiungiUrl + '?qty=' + qty);
            await aggiornaBadge();
            bootstrap.Toast.getOrCreateInstance(
                document.getElementById('toastCarrello')
            ).show();
        }

        /* Bottoni "+" nei consigliati */
        document.querySelectorAll('.rec-add-btn').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                e.stopPropagation();
                const id = btn.dataset.id;
                await fetch(`/Carrello/MettiNelCarrello?id=${id}`, { method: 'POST' });

                btn.textContent = '✓';
                btn.disabled    = true;
                setTimeout(() => { btn.textContent = '+'; btn.disabled = false; }, 1200);

                bootstrap.Toast.getOrCreateInstance(
                    document.getElementById('toastCarrello')
                ).show();

                await aggiornaBadge();
            });
        });

        /* Badge al caricamento */
        aggiornaBadge();

        /* Preferiti */
        const btnPreferito = document.getElementById('btn-preferito');
        if (btnPreferito) {
            btnPreferito.addEventListener('click', async () => {
                const res = await fetch('/Articoli/TogglePreferito?idArticolo=@art.IdArticolo',
                    { method: 'POST' });
                if (res.ok) btnPreferito.classList.toggle('attivo');
            });
        }
    </script>
}
