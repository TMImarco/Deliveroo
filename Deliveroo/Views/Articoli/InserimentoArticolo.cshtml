@using Deliveroo.Tabelle
@model Deliveroo.Models.InserimentoArticoloViewModel
@inject GestioneDati Gestione
@{
    ViewData["Title"] = "Articoli";
    Layout = "_Layout";
    Articolo art = Model.ArticoloScelto;
    
    <!-- prendo tutte le categorie per visualizzarle nella tab bar -->
    var categorie = Gestione.GetTutteCategorie();
    
    <!-- per personalizzare la navbar, tengo conto della categoria selezionata da evidenziarla -->
    var currentCategoria = ViewContext.RouteData.Values["categoria"]?.ToString() 
                           ?? Context.Request.Query["categoria"].ToString();
}

@section NavbarLinks {
    
    <!-- LA TAB BAR -->
    <div class="navbar-collapse collapse">
        <ul class="navbar-nav flex-row gap-3">
            @foreach (var cat in categorie)
            {
                var isActive = currentCategoria == cat.Nome ? "active" : "";
                <li class="nav-item">
                    <a class="nav-link text-dark @isActive"
                       asp-controller="Articoli"
                       asp-action="Articoli"
                       asp-route-idCategoria="@cat.IdCategoria">
                        @cat.Nome
                    </a>
                </li>
            }
        </ul>
    </div>
    
    <div class="search-wrapper ms-auto">
        <!-- BOTTONE BACK -->
        <a class="search-toggle back-btn" asp-action="Articoli" asp-controller="Articoli" title="Torna alla home"
           asp-route-idCategoria="@art.Categoria.IdCategoria">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2.2"
                 stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </a>
    </div>
}

<div class="macro-section">
    <div class="container">
        <div class="page-split">

            <!-- SINISTRA -->
            <div class="left-col">

                <!-- NAVIGAZIONE PREV / NEXT 
                Piuttosto di ritornare sempre alla pagina di tutti gli articoli, ci sono i bottoni avanti e indietro per navigare facilmente -->
                <div class="article-nav">
                    @if (ViewBag.IdPrev != null)
                    {
                        <a class="nav-arrow prev" asp-action="InserimentoArticolo" asp-route-id="@ViewBag.IdPrev">&#8592;</a>
                    }
                    else
                    {
                        <span class="nav-arrow prev disabled">&#8592;</span>
                    }

                    @if (ViewBag.IdNext != null)
                    {
                        <a class="nav-arrow next" asp-action="InserimentoArticolo" asp-route-id="@ViewBag.IdNext">&#8594;</a>
                    }
                    else
                    {
                        <span class="nav-arrow next disabled">&#8594;</span>
                    }
                </div>

                <div class="article-split">
                    <div class="article-left">
                        <img src="@art.ImageUrl"
                             alt="@art.Nome"
                             class="article-left"
                             loading="lazy"/>
                    </div>
                    <div class="article-right">
                        <div class="article-right-content">
                            <h1>@art.Nome</h1>
                            <p class="descrizione">@art.Descrizione</p>
                            <div class="article-divider"></div>
                            <p class="prezzo">€ @art.Prezzo.ToString("0.00")</p>
                            <div class="article-divider"></div>
                            <div class="qty-add-row">
                                <div class="qty-row">
                                    <button class="qty-btn" onclick="cambiaQty(-1)">−</button>
                                    <span class="qty-val" id="qty">1</span>
                                    <button class="qty-btn" onclick="cambiaQty(1)">+</button>
                                </div>
                            </div>
                        </div>
                        <button id="btn-aggiungi" class="add-btn" onclick="aggiungiAlCarrello()">Aggiungi</button>
                    </div>
                </div>

                @section AboveNavbar {
                    <div class="total-overlay">
                        <span class="label">Totale: </span>
                        <span class="valore" id="totale">€ @art.Prezzo.ToString("0.00")</span>
                    </div>
                }

            </div>

            <!-- DESTRA (raccomandazioni future) -->
            <div class="right-col">
                <div class="col-header">
                    <h2>Consigliati per te</h2>
                </div>
                @if (Model.Raccomandazioni != null && Model.Raccomandazioni.Any())
                {
                    <div class="rec-list">
                        @foreach (var articolo in Model.Raccomandazioni)
                        {
                            <div class="rec-row">
                                <a asp-action="InserimentoArticolo" asp-route-id="@articolo.IdArticolo" class="rec-link">
                                    <img class="rec-thumb" src="@Url.Content(articolo.ImageUrl)" alt="@articolo.Nome"/>
                                    <div class="rec-info">
                                        <div class="rec-name">@articolo.Nome</div>
                                        <div class="rec-price">€@articolo.Prezzo.ToString("F2")</div>
                                    </div>
                                </a>

                                <button class="rec-add-btn"
                                        id="btn-aggiungi"
                                        data-id="@articolo.IdArticolo"
                                        data-nome="@articolo.Nome"
                                        data-prezzo="@articolo.Prezzo"
                                        data-image="@articolo.ImageUrl"
                                        onclick="aggiungiAlCarrello()">+</button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="padding: 20px; color: #aaa; font-size: 13px; text-align: center;">
                        Nessun consiglio disponibile
                    </div>
                }
            </div>

        </div>
    </div>
</div>

<!-- TOAST CONFERMA AGGIUNTA -->
<div class="toast-container position-fixed bottom-0 start-50 translate-middle-x p-3" style="z-index: 9999">
    <div id="toastCarrello" class="toast align-items-center text-white border-0" role="alert" data-bs-delay="2000">
        <div class="toast-body d-flex align-items-center gap-2">
            <span style="font-size:1.2rem">🛒</span>
            <span>Articolo aggiunto al carrello!</span>
        </div>
    </div>
</div>

<!-- CARRELLO -->
<a asp-controller="Carrello" asp-action="Carrello" class="cart-fab" title="Carrello">
    🛒
    <span class="cart-badge"></span>
</a>

@section Styles {
    <link rel="stylesheet" href="/css/InserimentoArticolo.css"/>
}

@section Scripts {
    <script>
        /* AUMENTARE LA QUANTITA DELL'ARTICOLO */
        const prezzo = @Model.ArticoloScelto.Prezzo.ToString(System.Globalization.CultureInfo.InvariantCulture);
        const aggiungiUrl = '@Url.Action("MettiNelCarrello", "Carrello", new { id = Model.ArticoloScelto.IdArticolo })';
        let qty = 1;

        function aggiornaTotale() {
            document.getElementById('totale').textContent =
                '€ ' + (prezzo * qty).toFixed(2);
        }

        function cambiaQty(d) {
            qty = Math.max(1, qty + d);
            document.getElementById('qty').textContent = qty;
            aggiornaTotale();
        }

        /* AGGIORNARE IL BADGE */
        async function aggiornaBadge() {
            const res = await fetch('/Carrello/NumeroElementi');
            const count = await res.text();
            document.querySelectorAll('.cart-badge').forEach(b => b.textContent = count);
        }

        async function aggiungiAlCarrello() {
            const res = await fetch(aggiungiUrl + '?qty=' + qty);
            await aggiornaBadge();

            const toastEl = document.getElementById('toastCarrello');
            const toast = bootstrap.Toast.getOrCreateInstance(toastEl);
            toast.show();
        }

        // Badge al caricamento
        aggiornaBadge();
        
        /*BOTTONI DEI CONSIGLIATI PER TE
        document.querySelectorAll('.rec-add-btn').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                e.stopPropagation();

                const id      = btn.dataset.id;
                const nome    = btn.dataset.nome;
                const prezzo  = btn.dataset.prezzo;
                const image   = btn.dataset.image;

                await fetch('/Carrello/Incrementa', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ idArticolo: id, nome, prezzo, imageUrl: image })
                });

                // feedback visivo opzionale
                btn.textContent = '✓';
                btn.disabled = true;
                setTimeout(() => { btn.textContent = '+'; btn.disabled = false; }, 1000);
            });
        });*/
    </script>
}