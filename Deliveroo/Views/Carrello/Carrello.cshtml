@model Deliveroo.Models.CarrelloViewModel
@{
    ViewData["Title"] = "Articoli";
    Layout = "_Layout";

    var carrelloVuoto = false;
    if (Model.ArticoliCarrello.Count == 0)
    {
        carrelloVuoto = true;
    }
    else
    { carrelloVuoto = false; }
}

@section NavbarLinks {
    <!--<div class="search-wrapper ms-auto">
         BOTTONE BACK 
        <a class="search-toggle back-btn" href="@ViewBag.BackUrl" title="Torna al carrello">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2.2"
                 stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </a>
    </div>-->
}

<div class="macro-section">

    <div class="container">
        <div class="carrello-wrapper">

            <div class="left-col">
                <div class="col-header">
                    <h2>Carrello</h2>
                    <a href="@Url.Action("SvuotaCarrello")"
                       class="clear-btn confirm-action"
                       data-msg="Svuotare l'intero carrello?">Svuota</a>
                </div>

                <!-- SINISTRA -->
                <div class="item-list">
                    @if (Model != null && Model.ArticoliCarrello.Any())
                    {
                        @foreach (var gruppo in Model.ArticoliCarrello.GroupBy(a => a.IdArticolo))
                        {
                            var articolo = gruppo.First();
                            var quantita = gruppo.Count();
                            var prezzoTotale = articolo.Prezzo * quantita;

                            <div class="item-row">
                                <img class="item-thumb" src="@Url.Content(articolo.ImageUrl)" alt="@articolo.Nome"/>
                                <div class="item-info">
                                    <div class="item-name">@articolo.Nome</div>
                                    <div class="item-unit-price">€@articolo.Prezzo.ToString("F2") cad.</div>
                                </div>
                                <div class="qty-controls">
                                    @if (quantita == 1)
                                    {
                                        <a href="@Url.Action("Decrementa", new { id = articolo.IdArticolo })"
                                           class="qty-btn confirm-action"
                                           data-msg="Rimuovere @articolo.Nome dal carrello?">−</a>
                                    }
                                    else
                                    {
                                        <a asp-action="Decrementa" asp-route-id="@articolo.IdArticolo"
                                           class="qty-btn">−</a>
                                    }
                                    <span class="qty-val">@quantita</span>
                                    <a asp-action="Incrementa" asp-route-id="@articolo.IdArticolo" class="qty-btn">+</a>
                                </div>
                                <div class="item-price">€@prezzoTotale.ToString("F2")</div>
                                <a href="@Url.Action("Rimuovi", new { id = articolo.IdArticolo })"
                                   class="remove-btn confirm-action"
                                   data-msg="Rimuovere @articolo.Nome dal carrello?">✕</a>
                            </div>
                        }
                    }
                </div>

                @section AboveNavbar {
                    <div class="total-overlay">
                        <div>
                            <div class="footer-info">@Model.ArticoliCarrello.Count articoli</div>
                            <div class="footer-total">Totale:
                                €@Model.ArticoliCarrello.Sum(a => a.Prezzo).ToString("F2")</div>
                        </div>
                        <a href="@Url.Action("SvuotaCarrello")"
                           class="clear-btn confirm-action"
                           data-msg="Svuotare l'intero carrello?">Svuota</a>
                        <a asp-action="Riepilogo" asp-controller="Ordini"
                           class="procedi-btn @(carrelloVuoto ? "disabled" : "")"
                           aria-disabled="@(carrelloVuoto ? "true" : "false")">
                            Procedi
                        </a>
                    </div>
                }

            </div>

            <!-- DESTRA (raccomandazioni) -->
            <div class="right-col">
                <div class="col-header">
                    <h2>Consigliati per te</h2>
                </div>
                @if (Model.Raccomandazioni != null && Model.Raccomandazioni.Any())
                {
                    <div class="rec-list">
                        @foreach (var articolo in Model.Raccomandazioni)
                        {
                            <div class="rec-row">
                                <img class="rec-thumb" src="@Url.Content(articolo.ImageUrl)" alt="@articolo.Nome"/>
                                <div class="rec-info">
                                    <div class="rec-name">@articolo.Nome</div>
                                    <div class="rec-price">€@articolo.Prezzo.ToString("F2")</div>
                                </div>
                                <a asp-action="Incrementa" asp-route-id="@articolo.IdArticolo" class="rec-add-btn">+</a>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="padding: 20px; color: #aaa; font-size: 13px; text-align: center;">
                        Nessun consiglio disponibile
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- MODAL CONFERMA -->
<div id="confirm-modal" class="modal-overlay" style="display:none">
    <div class="modal-box">
        <p id="modal-msg"></p>
        <div class="modal-btns">
            <button id="modal-cancel" class="modal-btn cancel">Annulla</button>
            <button id="modal-confirm" class="modal-btn confirm">Conferma</button>
        </div>
    </div>
</div>

<!-- TOAST FEEDBACK -->
<div class="toast-container position-fixed bottom-0 start-50 translate-middle-x p-3" style="z-index: 9999">
    <div id="toastCarrello" class="toast align-items-center text-white border-0" role="alert" data-bs-delay="2000">
        <div class="toast-body d-flex align-items-center gap-2">
            <span id="toast-icon" style="font-size:1.2rem"></span>
            <span id="toast-msg"></span>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="/css/Carrello.css"/>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {

            /* ── MODAL CONFERMA ── */
            const modal = document.getElementById('confirm-modal');
            const modalMsg = document.getElementById('modal-msg');
            const btnConfirm = document.getElementById('modal-confirm');
            const btnCancel = document.getElementById('modal-cancel');
            let pendingUrl = null;

            document.querySelectorAll('.confirm-action').forEach(el => {
                el.addEventListener('click', e => {
                    e.preventDefault();
                    pendingUrl = el.getAttribute('href');
                    modalMsg.textContent = el.getAttribute('data-msg');
                    modal.style.display = 'flex';
                });
            });

            btnConfirm.addEventListener('click', () => {
                if (pendingUrl) window.location.href = pendingUrl;
            });

            btnCancel.addEventListener('click', () => {
                modal.style.display = 'none';
                pendingUrl = null;
            });

            modal.addEventListener('click', e => {
                if (e.target === modal) {
                    modal.style.display = 'none';
                    pendingUrl = null;
                }
            });

            /* ── TOAST DA TEMPDATA ── */
            @if (TempData["Toast"] != null)
            {
                var msg = TempData["Toast"].ToString();
                var icon = msg.Contains("svuotato") ? "🗑️" : "✕";
                <text>
                    document.getElementById('toast-msg').textContent = '@msg';
                    document.getElementById('toast-icon').innerHTML = '@icon';
                    const toastEl = document.getElementById('toastCarrello');
                    bootstrap.Toast.getOrCreateInstance(toastEl).show();
                </text>
            }

        });
    </script>
}