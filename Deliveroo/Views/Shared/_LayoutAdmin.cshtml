<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Deliveroo Admin Dashboard</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/Deliveroo.styles.css" asp-append-version="true"/>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- ___________ SIDEBAR ___________-->
<!-- Burger Button -->
<button class="burger-btn" onclick="toggleSidebar()">&#9776;</button>

<!-- Sidebar Overlay -->
<div class="sidebar-overlay" onclick="toggleSidebar()"></div>

<!-- Sidebar -->
<div class="sidebar">
    <nav>
        <a asp-controller="Home" asp-action="IndexAdmin">Admin Dashboard </a>
        <a asp-controller="Home" asp-action="Privacy">Privacy</a>

        <a asp-controller="Home" asp-action="Logout" class="sidebar-logout">Esci</a>
    </nav>
</div>
<!-- ___________ NAVBAR ___________-->
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container justify-content-center">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="IndexAdmin">
                <h2 class="section-title">
                    Deliveroo
                    <small class="text-muted">admin dashboard</small>
                </h2>
            </a>
            
            <!-- se la vista dichiara "section Styles" il CSS aggiuntivo viene caricato nell'<head> -->
            @await RenderSectionAsync("NavbarLinks", required: false)
        </div>
    </nav>
</header>


<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - Deliveroo - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)

<!-- ___________ SCRIPT per il funzionamento della SIDEBAR ___________-->
<script>
    function toggleSidebar() {
        document.querySelector('.sidebar').classList.toggle('open');
        document.querySelector('.sidebar-overlay').classList.toggle('active');
    }
</script>
</body>
</html>