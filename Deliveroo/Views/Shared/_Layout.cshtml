<!--LAYOUT NORMALE DELLA HOME QUANDO ENTRI INIZIALMENTE (COME UTENTE NORMALE)-->

@inject GestioneDati g
@{
    var categorie = g.GetCategorie();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Deliveroo</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/Deliveroo.styles.css" asp-append-version="true"/>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container justify-content-center">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <h2 class="section-title">Deliveroo</h2>
            </a>
        </div>
    </nav>
</header>

<!-- MACRO CATEGORIE -->
<div class="macro-section">
    <div class="container">
        <div class="macro-grid">
            @foreach (var categoria in categorie)
            {
                <div class="macro-item">
                    <a href="#" class="macro-main-box">
                        @categoria
                    </a>

                    <div class="macro-sub-row">
                        <div class="macro-sub-box"></div>
                        <div class="macro-sub-box"></div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>


<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<!-- CARRELLO FAB -->
<a href="#" class="cart-fab" title="Carrello">
    🛒
    <span class="cart-badge">0</span>
</a>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - Deliveroo - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>