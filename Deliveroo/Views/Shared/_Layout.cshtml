<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Deliveroo</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Deliveroo.styles.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <!-- se la vista dichiara "section NavbarLinks" il contenuto viene inserito qui -->
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- ___________ SIDEBAR ___________-->
<!-- Burger Button -->
<button class="burger-btn" onclick="toggleSidebar()" title="Menu">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2.2"
         stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
</button>

<!-- Sidebar Overlay -->
<div class="sidebar-overlay" onclick="toggleSidebar()"></div>

<!-- Sidebar -->
<div class="sidebar">
    <nav>
        <a asp-controller="Home" asp-action="Index">Home</a>
        <a asp-controller="Auth" asp-action="LoginAdmin">Admin</a>
        <a asp-controller="Home" asp-action="Privacy">Privacy</a>
    </nav>
</div>

<!-- ___________ NAVBAR ___________-->
<header class="sticky-top">
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container justify-content-center">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <h2 class="section-title">Deliveroo</h2>
            </a>

            <!-- se la vista dichiara "section Styles" il CSS aggiuntivo viene caricato nell'<head> -->
            @await RenderSectionAsync("NavbarLinks", required: false)
        </div>
    </nav>
</header>

<!-- ___________ BODY ___________-->
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<!-- ___________ FOOTER ___________
<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - Deliveroo - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
</footer>-->

<!-- ___________ BOTTOM NAVBAR ___________-->
@RenderSection("AboveNavbar", required: false)
<nav class="bottom-navbar">
</nav>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)

<!-- ___________ SCRIPT per il funzionamento della SIDEBAR ___________-->
<script>
    function toggleSidebar() {
        document.querySelector('.sidebar').classList.toggle('open');
        document.querySelector('.sidebar-overlay').classList.toggle('active');
    }
</script>

<!-- ___________ SCRIPT per il funzionamento del BADGE DEL CARRELLO (il numero in alto a destra del bottoncino) ___________-->
<script>
    async function aggiornaBadge() {
        const res = await fetch('/Carrello/NumeroElementi');
        const count = await res.text();
        document.querySelectorAll('.cart-badge').forEach(b => b.textContent = count);
    }

    aggiornaBadge();
    setInterval(aggiornaBadge, 2000); // ogni 2 secondi
</script>
</body>
</html>
