@using Deliveroo.Tabelle
@model List<Deliveroo.Tabelle.Articolo>
@{
    ViewData["Title"] = "Riepilogo Ordine";
    Layout = "_Layout";
}

<div class="macro-section">

    <!-- BOTTONE BACK -->
    <a class="nav-arrow back-btn" href="@ViewBag.BackUrl">↵</a>
    <div class="container riepilogo-container">
        <h1 class="riepilogo-title">Riepilogo Ordine</h1>
        <div class="riepilogo-grid">

            <!-- COLONNA SINISTRA: articoli + dati utente -->
            <div class="riepilogo-left">

                <!-- ARTICOLI NEL CARRELLO -->
                <section class="riepilogo-card">
                    <h2 class="card-section-title">🛒 Il tuo ordine</h2>
                    @if (Model != null && Model.Any())
                    {
                        <ul class="articoli-list">
                            @foreach (var gruppo in Model.GroupBy(a => a.IdArticolo))
                            {
                                var articolo = gruppo.First();
                                var quantita = gruppo.Count();
                                <li class="articolo-row">
                                    <span class="articolo-nome">@articolo.Nome</span>
                                    @if (quantita > 1)
                                    {
                                        <span class="articolo-qty">x @quantita</span>
                                    }
                                    <span
                                        class="articolo-prezzo">€ @((articolo.Prezzo * quantita).ToString("F2"))</span>
                                </li>
                            }
                        </ul>
                        <div class="totale-row">
                            <span class="totale-label">Totale</span>
                            <span class="totale-prezzo">€ @Model.Sum(a => a.Prezzo).ToString("F2")</span>
                        </div>
                    }
                    else
                    {
                        <p class="carrello-vuoto">Il carrello è vuoto.</p>
                    }
                </section>

                <!-- DATI PERSONALI E INDIRIZZO -->
                <section class="riepilogo-card">
                    <h2 class="card-section-title">📦 Dati di consegna</h2>

                    <form asp-action="Conferma" asp-controller="Ordini" method="post" id="formOrdine">
                        @Html.AntiForgeryToken()

                        <div class="form-group">
                            <label for="nome">Nome e Cognome</label>
                            <input type="text" id="nome" name="NomeCliente" class="form-input"
                                   placeholder="Es. Mario Rossi"
                                   maxlength="60"
                                   required/>
                        </div>

                        <div class="form-group">
                            <label for="indirizzo">Indirizzo di consegna</label>
                            <input type="text" id="indirizzo" name="Indirizzo" class="form-input"
                                   placeholder="Es. Via Roma 10, Milano" required/>
                        </div>

                        <div class="form-group">
                            <label for="telefono">Numero di telefono</label>
                            <input type="tel" id="telefono" name="Telefono" class="form-input"
                                   placeholder="Es. +39 333 1234567"
                                   maxlength="15"
                                   required/>
                        </div>

                        <!-- METODO DI PAGAMENTO -->
                        <section class="riepilogo-card pagamento-card">
                            <h2 class="card-section-title">💳 Metodo di pagamento</h2>

                            <div class="pagamento-options">

                                <label class="pagamento-option">
                                    <input type="radio" name="MetodoPagamento" value="carta" required/>
                                    <span class="pagamento-icon">💳</span>
                                    <span class="pagamento-label">Carta di credito / debito</span>
                                </label>

                                <label class="pagamento-option">
                                    <input type="radio" name="MetodoPagamento" value="paypal"/>
                                    <span class="pagamento-icon">🅿️</span>
                                    <span class="pagamento-label">PayPal</span>
                                </label>

                                <label class="pagamento-option">
                                    <input type="radio" name="MetodoPagamento" value="contanti"/>
                                    <span class="pagamento-icon">💵</span>
                                    <span class="pagamento-label">Contanti alla consegna</span>
                                </label>

                            </div>
                        </section>
                    </form>
                </section>

            </div>

        </div>
    </div>
</div>

<!-- MODAL PAGAMENTO -->
<div id="modalPagamento" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <h2 class="card-section-title">💳 Dati carta</h2>

        <div class="form-group">
            <label>Numero carta</label>
            <input type="text" id="numeroCarta" class="form-input" placeholder="1234 5678 9012 3456" maxlength="19"/>
        </div>
        <div class="form-group">
            <label>Intestatario</label>
            <input type="text" id="intestatario" class="form-input" placeholder="Mario Rossi" maxlength="60"/>
        </div>
        <div class="modal-row">
            <div class="form-group">
                <label>Scadenza</label>
                <input type="text" id="scadenza" class="form-input" placeholder="MM/AA" maxlength="5"/>
            </div>
            <div class="form-group">
                <label>CVV</label>
                <input type="text" id="cvv" class="form-input" placeholder="123" maxlength="3" style="width: 80px;"/>
            </div>
        </div>

        <div class="modal-actions">
            <button type="button" class="btn-annulla" onclick="chiudiModal()">Annulla</button>
            <button type="button" class="btn-conferma-carta" onclick="confermaCarta()">Conferma</button>
        </div>
    </div>
</div>

@section AboveNavbar {
    <div class="total-overlay">
        <div>
            <div class="footer-info">@Model.Count articoli</div>
            <div class="footer-total">Totale: €@Model.Sum(a => a.Prezzo).ToString("F2")</div>
        </div>
        <button type="submit" form="formOrdine" class="procedi-btn" @(Model == null || !Model.Any() ? "disabled" : "")>
            Conferma ordine →
        </button>
    </div>
}


@section Styles {
    <link rel="stylesheet" href="/css/Riepilogo.css"/>
}

@section Scripts {
    <script>
        //controllo formattazione nome e telefono
        const nome = document.getElementById('nome');
        const telefono = document.getElementById('telefono');

        // Blocca input non valido in tempo reale
        nome.addEventListener('input', function () {
            this.value = this.value.replace(/[^A-Za-zÀ-ÖØ-öø-ÿ\s']/g, '');
        });

        telefono.addEventListener('input', function () {
            this.value = this.value.replace(/[^\d\+\s\-]/g, '');
        })

        //popup del pagamento
        document.querySelectorAll('input[name="MetodoPagamento"]').forEach(radio => {
            radio.addEventListener('change', function () {
                if (this.value === 'carta' || this.value === 'paypal') {
                    document.getElementById('modalPagamento').style.display = 'flex';
                }
            });
        });

        function chiudiModal() {
            document.getElementById('modalPagamento').style.display = 'none';
            document.querySelectorAll('input[name="MetodoPagamento"]').forEach(r => r.checked = false);
        }

        function confermaCarta() {
            document.getElementById('modalPagamento').style.display = 'none';
        }
    </script>
}
