@model List<Deliveroo.Tabelle.Ordine>
@using Deliveroo.Tabelle
@{
    ViewData["Title"] = "I tuoi ordini";
    Layout = "_Layout";
    var righePerOrdine = ViewBag.RighePerOrdine as Dictionary<int, List<RigaDettaglio>>;
}

@section NavbarLinks { }

<div class="preferiti-hero">
    <div class="preferiti-hero__inner">
        <span class="preferiti-eyebrow">Il tuo storico</span>
        <h1 class="preferiti-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26"
                 viewBox="0 0 24 24" fill="none" stroke="#00ccbc"
                 stroke-width="2" style="vertical-align:-4px;margin-right:8px">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
            Ordini passati
        </h1>
        <p class="preferiti-subtitle">
            @Model.Count ordin@(Model.Count == 1 ? "e effettuato" : "i effettuati")
        </p>
    </div>
</div>

<div class="preferiti-container">

    @if (!Model.Any())
    {
        <div class="preferiti-empty">
            <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56"
                 viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
            </svg>
            <p>Non hai ancora effettuato nessun ordine.</p>
            <a asp-controller="Home" asp-action="Index" class="btn-teal">
                Inizia ad ordinare
            </a>
        </div>
    }
    else
    {
        <div class="ordini-list">
            @foreach (var ordine in Model)
            {
                var righe = righePerOrdine?[ordine.IdOrdine] ?? new List<RigaDettaglio>();
                int totArticoli = righe.Sum(r => r.Quantita);

                <div class="ordine-card fadeUp">

                    <!-- HEADER cliccabile per aprire/chiudere -->
                    <div class="ordine-card__header" onclick="toggleOrdine(@ordine.IdOrdine)">
                        <div class="ordine-card__meta">
                            <div class="ordine-card__top-row">
                                <span class="ordine-card__id">#@ordine.IdOrdine</span>
                                <span class="ordine-card__badge">@totArticoli articol@(totArticoli == 1 ? "o" : "i")</span>
                            </div>
                            <span class="ordine-card__data">
                                @ordine.Data.ToString("dd MMM yyyy · HH:mm")
                            </span>
                        </div>
                        <div class="ordine-card__right">
                            <span class="ordine-card__totale">€ @ordine.ImportoTotale.ToString("F2")</span>
                            <svg class="ordine-chevron" id="chev-@ordine.IdOrdine"
                                 xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                 viewBox="0 0 24 24" fill="none" stroke="#aaa"
                                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="6 9 12 15 18 9"/>
                            </svg>
                        </div>
                    </div>

                    <!-- CORPO collassabile -->
                    <div class="ordine-card__body" id="body-@ordine.IdOrdine">
                        <div class="ordine-card__righe">
                            @foreach (var riga in righe)
                            {
                                <div class="ordine-riga">
                                    <span class="ordine-riga__qty">×@riga.Quantita</span>
                                    <span class="ordine-riga__nome">@riga.NomeArticolo</span>
                                    <span class="ordine-riga__prezzo">€ @riga.Prezzo.ToString("F2")</span>
                                </div>
                            }
                        </div>
                        <div class="ordine-card__footer">
                            <span class="ordine-card__footer-label">
                                Totale pagato
                                <strong>€ @ordine.ImportoTotale.ToString("F2")</strong>
                            </span>
                            <button class="btn-teal btn-teal--sm"
                                    onclick="riordina(@ordine.IdOrdine)">
                                Riordina
                            </button>
                        </div>
                    </div>

                </div>
            }
        </div>
    }

</div>

@section Scripts {
<script>
function toggleOrdine(id) {
    const body  = document.getElementById('body-' + id);
    const chev  = document.getElementById('chev-' + id);
    const aperto = body.classList.toggle('aperto');
    chev.style.transform = aperto ? 'rotate(180deg)' : 'rotate(0deg)';
}

async function riordina(idOrdine) {
    const res = await fetch('/Ordini/RiordinaDa?idOrdine=' + idOrdine, { method: 'POST' });
    if (res.ok) window.location.href = '/Carrello/Carrello';
}
</script>
}